#! /bin/bash

[ -z "${ROCR_VISIBLE_DEVICES}" ] && { echo "Error: ROCR_VISIBLE_DEVICES not set" >&2; exit 1; }

if [[ -n "${VLLM_PORT:-}" ]]; then
  :
else
  # Port suffix must be a single integer; use the first device if a list is given.
  PORT="${ROCR_VISIBLE_DEVICES%%,*}"
  PORT="${PORT//[[:space:]]/}"
  if ! [[ "${PORT}" =~ ^[0-9]+$ ]]; then
    echo "error: first GPU index in ROCR_VISIBLE_DEVICES must be a non-negative integer (got: ${ROCR_VISIBLE_DEVICES})" >&2
    exit 1
  fi
  if [[ "${ROCR_VISIBLE_DEVICES}" == *","* ]]; then
    echo "vllm-benchmark: using first index ${PORT} from ROCR_VISIBLE_DEVICES=${ROCR_VISIBLE_DEVICES} for VLLM_PORT" >&2
  fi
  VLLM_PORT="800${PORT}"
fi

python3 /app/LMCache/benchmarks/long_doc_qa/long_doc_qa.py \
    --port "${VLLM_PORT}" \
    --model openai/gpt-oss-120b  \
    --num-documents 100 \
    --document-length 100000 \
    --output-len 100 \
    --repeat-count 3 \
    --repeat-mode tile \
    --max-inflight-requests 4 \
    --sleep-time-after-warmup 15 \
    --completions \
    --json-output \
    --trim-fraction 0.1
