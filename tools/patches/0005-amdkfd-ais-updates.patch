+/*
+ * Parse BDF string "DDDD:BB:DD.F" or "BB:DD.F". Returns pci_dev with ref
+ * held, or NULL. Caller must pci_dev_put().
+ */
+static struct pci_dev *kfd_ais_pci_dev_from_bdf(const char *bdf)
+{
+	unsigned int domain = 0, bus, dev, func;
+	int n;
+
+	if (!bdf || !bdf[0])
+		return NULL;
+	n = sscanf(bdf, "%x:%x:%x.%x", &domain, &bus, &dev, &func);
+	if (n == 4)
+		return pci_get_domain_bus_and_slot(domain, bus, PCI_DEVFN(dev, func));
+	n = sscanf(bdf, "%x:%x.%x", &bus, &dev, &func);
+	if (n == 3)
+		return pci_get_domain_bus_and_slot(0, bus, PCI_DEVFN(dev, func));
+	return NULL;
+}
+
+static ssize_t kfd_ais_attr_buffer_pinning_show(struct kobject *kobj,
+						struct attribute *attr, char *buf)
+{
+	bool v;
+
+	mutex_lock(&kfd_ais_sysfs_mutex);
+	v = kfd_ais_buffer_pinning_enabled_var;
+	mutex_unlock(&kfd_ais_sysfs_mutex);
+	return sysfs_emit(buf, "%u\n", v ? 1 : 0);
+}
+
+static ssize_t kfd_ais_attr_buffer_pinning_store(struct kobject *kobj,
+						 struct attribute *attr,
+						 const char *buf, size_t count)
+{
+	unsigned int v;
+
+	if (kstrtouint(buf, 0, &v) != 0 || v > 1)
+		return -EINVAL;
+	mutex_lock(&kfd_ais_sysfs_mutex);
+	kfd_ais_buffer_pinning_enabled_var = (v != 0);
+	mutex_unlock(&kfd_ais_sysfs_mutex);
+	return count;
+}
+
+static ssize_t kfd_ais_attr_p2pdma_use_cache_show(struct kobject *kobj,
+						  struct attribute *attr,
