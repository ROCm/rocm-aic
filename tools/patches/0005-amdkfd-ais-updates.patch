+static ssize_t kfd_ais_attr_pci_bdf_show(struct kobject *kobj,
+					 struct attribute *attr, char *buf)
+{
+	ssize_t len;
+
+	mutex_lock(&kfd_ais_sysfs_mutex);
+	len = sysfs_emit(buf, "%s\n", kfd_ais_pci_bdf_buf);
+	mutex_unlock(&kfd_ais_sysfs_mutex);
+	return len;
+}
+
+static ssize_t kfd_ais_attr_pci_bdf_store(struct kobject *kobj,
+					  struct attribute *attr,
+					  const char *buf, size_t count)
+{
+	char tmp[AIS_PCI_BDF_MAX_LEN];
+	unsigned int d, b, dev, f;
+	int n;
+
+	if (count >= AIS_PCI_BDF_MAX_LEN)
+		return -EINVAL;
+	memcpy(tmp, buf, count);
+	tmp[count] = '\0';
+	/* Trim trailing newline */
+	if (count > 0 && tmp[count - 1] == '\n')
+		tmp[count - 1] = '\0';
+	/* Validate: DDDD:BB:DD.F or BB:DD.F */
+	n = sscanf(tmp, "%x:%x:%x.%x", &d, &b, &dev, &f);
+	if (n == 4)
+		goto valid;
+	n = sscanf(tmp, "%x:%x.%x", &b, &dev, &f);
+	if (n != 3)
+		return -EINVAL;
+valid:
+	mutex_lock(&kfd_ais_sysfs_mutex);
+	strscpy(kfd_ais_pci_bdf_buf, tmp, AIS_PCI_BDF_MAX_LEN);
+	mutex_unlock(&kfd_ais_sysfs_mutex);
+	return count;
+}
