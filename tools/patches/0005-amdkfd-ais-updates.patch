+static ssize_t kfd_ais_sysfs_attr_show(struct kobject *kobj,
+				       struct attribute *attr, char *buf)
+{
+	if (!strcmp(attr->name, "buffer_pinning"))
+		return kfd_ais_attr_buffer_pinning_show(kobj, attr, buf);
+	if (!strcmp(attr->name, "p2pdma_distance_use_cache"))
+		return kfd_ais_attr_p2pdma_use_cache_show(kobj, attr, buf);
+	if (!strcmp(attr->name, "p2pdma_distance"))
+		return kfd_ais_attr_p2pdma_distance_show(kobj, attr, buf);
+	if (!strcmp(attr->name, "pci_bdf_override"))
+		return kfd_ais_attr_pci_bdf_override_show(kobj, attr, buf);
+	if (!strcmp(attr->name, "pci_bdf"))
+		return kfd_ais_attr_pci_bdf_show(kobj, attr, buf);
+	return 0;
+}
+
+static ssize_t kfd_ais_sysfs_attr_store(struct kobject *kobj,
+					struct attribute *attr,
+					const char *buf, size_t count)
+{
+	if (!strcmp(attr->name, "buffer_pinning"))
+		return kfd_ais_attr_buffer_pinning_store(kobj, attr, buf, count);
+	if (!strcmp(attr->name, "p2pdma_distance_use_cache"))
+		return kfd_ais_attr_p2pdma_use_cache_store(kobj, attr, buf,
+							   count);
+	if (!strcmp(attr->name, "p2pdma_distance"))
+		return kfd_ais_attr_p2pdma_distance_store(kobj, attr, buf,
+							  count);
+	if (!strcmp(attr->name, "pci_bdf_override"))
+		return kfd_ais_attr_pci_bdf_override_store(kobj, attr, buf,
+							   count);
+	if (!strcmp(attr->name, "pci_bdf"))
+		return kfd_ais_attr_pci_bdf_store(kobj, attr, buf, count);
+	return count;
+}
