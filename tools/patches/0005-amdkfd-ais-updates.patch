+static const struct sysfs_ops kfd_ais_sysfs_ops = {
+	.show = kfd_ais_sysfs_attr_show,
+	.store = kfd_ais_sysfs_attr_store,
+};
+
+static const struct kobj_type kfd_ais_ktype = {
+	.sysfs_ops = &kfd_ais_sysfs_ops,
+};
+
+static struct attribute_group kfd_ais_attr_group = {
+	.attrs = kfd_ais_attrs,
+};
+
+int kfd_ais_sysfs_init(void)
+{
+	int ret;
+
+	if (!kfd_device)
+		return -ENODEV;
+	sysfs_attr_init(&kfd_ais_attr_buffer_pinning);
+	sysfs_attr_init(&kfd_ais_attr_p2pdma_use_cache);
+	sysfs_attr_init(&kfd_ais_attr_p2pdma_distance);
+	sysfs_attr_init(&kfd_ais_attr_pci_bdf_override);
+	sysfs_attr_init(&kfd_ais_attr_pci_bdf);
+	kfd_ais_kobj = kzalloc(sizeof(*kfd_ais_kobj), GFP_KERNEL);
+	if (!kfd_ais_kobj)
+		return -ENOMEM;
+	ret = kobject_init_and_add(kfd_ais_kobj, &kfd_ais_ktype,
+				   &kfd_device->kobj, "ais");
+	if (ret) {
+		kobject_put(kfd_ais_kobj);
+		kfd_ais_kobj = NULL;
+		return ret;
+	}
+	ret = sysfs_create_group(kfd_ais_kobj, &kfd_ais_attr_group);
+	if (ret) {
+		kobject_del(kfd_ais_kobj);
+		kobject_put(kfd_ais_kobj);
+		kfd_ais_kobj = NULL;
+		return ret;
+	}
+	return 0;
+}
+
+void kfd_ais_sysfs_fini(void)
+{
+	if (kfd_ais_kobj) {
+		sysfs_remove_group(kfd_ais_kobj, &kfd_ais_attr_group);
+		kobject_del(kfd_ais_kobj);
+		kobject_put(kfd_ais_kobj);
+		kfd_ais_kobj = NULL;
+	}
+}
