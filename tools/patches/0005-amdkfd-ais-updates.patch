+
+	mutex_lock(&kfd_ais_sysfs_mutex);
+	v = kfd_ais_p2pdma_use_cache_var;
+	mutex_unlock(&kfd_ais_sysfs_mutex);
+	return sysfs_emit(buf, "%u\n", v ? 1 : 0);
+}
+
+static ssize_t kfd_ais_attr_p2pdma_use_cache_store(struct kobject *kobj,
+						   struct attribute *attr,
+						   const char *buf, size_t count)
+{
+	unsigned int v;
+
+	if (kstrtouint(buf, 0, &v) != 0 || v > 1)
