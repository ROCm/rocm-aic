--- a/amd/dkms/pre-build.sh
+++ b/amd/dkms/pre-build.sh
@@ -96,5 +96,12 @@
 unset TMPDIR
 
+# Provide vmlinux for BTF generation when building out-of-tree (e.g. DKMS)
+KVER="${KERNELRELEASE:-$(uname -r)}"
+KDIR="/lib/modules/${KVER}/build"
+if [ -r /sys/kernel/btf/vmlinux ] && [ ! -e "${KDIR}/vmlinux" ] && [ -w "${KDIR}" ]; then
+  ln -sf /sys/kernel/btf/vmlinux "${KDIR}/vmlinux" || true
+fi
+
 (cd $SRC && ./configure CC=${CC} > /tmp/amdgpu-configure.$$.log 2>&1; r=$?; grep -v 'checking for nproc\.\.\. (cached) yes' /tmp/amdgpu-configure.$$.log; rm -f /tmp/amdgpu-configure.$$.log; exit $r)
 
 # rename CFLAGS_ target.o / CFLAGS_REMOVE_ to CFLAGS_target.o
