From 9a96a98ef0d37ce81937d56d33f4154d15f5c8dc Mon Sep 17 00:00:00 2001
From: Amir Shetaia <amir.shetaia@amd.com>
Date: Tue, 24 Feb 2026 14:39:36 -0500
Subject: [PATCH 1/2] drm/amdkfd: Fix scheduling while atomic in AIS counter
 updates

Fix a "BUG: scheduling while atomic" kernel panic in
kfd_ais_update_counters() that occurs during high-concurrency I/O
workloads with 64+ threads. The function was holding xa_lock (spinlock)
while calling sysfs_create_file(), which can sleep by acquiring a
semaphore in kernfs_activate().

The issue manifests when multiple threads simultaneously perform I/O
operations through different PCIe storage devices, causing concurrent
calls to update AIS counters. The xa_lock spinlock disables preemption,
and any attempt to call a sleeping function while holding it triggers
the kernel's "scheduling while atomic" detection.

The fix restructures the locking to release xa_lock before any
operations that can sleep:

Fast path (existing counter):
- Acquire xa_lock briefly to xa_load() and update counter
- Release lock immediately
- No sysfs operations needed

Slow path (new counter):
- Allocate memory outside lock (GFP_KERNEL allowed)
- Acquire xa_lock briefly for __xa_insert() with GFP_ATOMIC
- Release lock before sysfs_create_file() calls
- Handle race condition where another thread created the same entry

The race condition in the slow path is handled by freeing the newly
allocated counter and updating the existing one that won the race,
ensuring no memory leaks or lost counter updates.

Error trace before fix:
  kfd_ais_update_counters
    xa_lock() <- spinlock acquired
    sysfs_create_file()
      kernfs_activate()
        down_write() <- tries to sleep
          BUG: scheduling while atomic

After fix:
  xa_lock()
  xa_load/xa_insert
  xa_unlock() <- released before sysfs
  sysfs_create_file() <- can sleep safely

Tested with 64 and 128 concurrent fio threads - no kernel panics
observed.

Fixes: a6b70a894b60 ("drm/amdkfd: Add sysfs entries for AIS transfers")

Signed-off-by: Amir Shetaia <amir.shetaia@amd.com>
---
 drivers/gpu/drm/amd/amdkfd/kfd_ais.c | 79 +++++++++++++++++++---------
 1 file changed, 55 insertions(+), 24 deletions(-)

diff --git a/drivers/gpu/drm/amd/amdkfd/kfd_ais.c b/drivers/gpu/drm/amd/amdkfd/kfd_ais.c
index 7eea81b7d54a..82b6d351fd0f 100644
--- a/drivers/gpu/drm/amd/amdkfd/kfd_ais.c
+++ b/drivers/gpu/drm/amd/amdkfd/kfd_ais.c
@@ -200,8 +200,10 @@ static int kfd_ais_update_counters(uint64_t size_copied, struct pci_dev *pdev,
 				    struct kfd_process_device *pdd, bool is_read)
 {
 	struct ais_counter_entry *counter;
+	struct ais_counter_entry *new_counter = NULL;
 	int ret = 0;
 
+	/* Fast path: update existing counter */
 	xa_lock(&pdd->ais_counters_xa);
 	counter = (struct ais_counter_entry *)xa_load(&pdd->ais_counters_xa, pdev->devfn);
 	if (counter) {
@@ -209,44 +211,73 @@ static int kfd_ais_update_counters(uint64_t size_copied, struct pci_dev *pdev,
 			counter->bytes_read += size_copied;
 		else
 			counter->bytes_written += size_copied;
-
-		goto out;
+		xa_unlock(&pdd->ais_counters_xa);
+		return 0;
 	}
+	xa_unlock(&pdd->ais_counters_xa);
 
-	counter = kzalloc(sizeof(struct ais_counter_entry), GFP_KERNEL);
-	if (!counter) {
-		ret = -ENOMEM;
-		goto out;
-	}
+	/* Slow path: create new counter entry (outside lock) */
+	new_counter = kzalloc(sizeof(struct ais_counter_entry), GFP_KERNEL);
+	if (!new_counter)
+		return -ENOMEM;
 
-	counter->pci_devfn = pdev->devfn;
+	new_counter->pci_devfn = pdev->devfn;
 	if (is_read)
-		counter->bytes_read = size_copied;
+		new_counter->bytes_read = size_copied;
 	else
-		counter->bytes_written = size_copied;
+		new_counter->bytes_written = size_copied;
 
-	ret = __xa_insert(&pdd->ais_counters_xa, pdev->devfn, counter, GFP_KERNEL);
-	if (ret) {
-		/* xa_insert failing means the entry is not empty, which shouldn't be possible */
-		kvfree(counter);
-		goto out;
+	/* Insert entry atomically */
+	xa_lock(&pdd->ais_counters_xa);
+	ret = __xa_insert(&pdd->ais_counters_xa, pdev->devfn, new_counter,
+			  GFP_ATOMIC);
+	xa_unlock(&pdd->ais_counters_xa);
+
+	if (ret == -EBUSY) {
+		/* Race: another thread created it - update and free ours */
+		kvfree(new_counter);
+		xa_lock(&pdd->ais_counters_xa);
+		counter = xa_load(&pdd->ais_counters_xa, pdev->devfn);
+		if (counter) {
+			if (is_read)
+				counter->bytes_read += size_copied;
+			else
+				counter->bytes_written += size_copied;
+		}
+		xa_unlock(&pdd->ais_counters_xa);
+		return 0;
 	}
 
-	ret = kfd_ais_init_attr(&counter->attr_bytes_read, pdev, true);
+	/* Successfully inserted - create sysfs (NO LOCK HELD - can sleep!) */
+	ret = kfd_ais_init_attr(&new_counter->attr_bytes_read, pdev, true);
 	if (ret)
-		goto out;
-	ret = sysfs_create_file(pdd->kobj_ais, &counter->attr_bytes_read);
+		goto cleanup_entry;
+	ret = sysfs_create_file(pdd->kobj_ais, &new_counter->attr_bytes_read);
 	if (ret)
-		goto out;
+		goto cleanup_attr_read;
 
-	ret = kfd_ais_init_attr(&counter->attr_bytes_written, pdev, false);
+	ret = kfd_ais_init_attr(&new_counter->attr_bytes_written, pdev, false);
 	if (ret)
-		goto out;
-	ret = sysfs_create_file(pdd->kobj_ais, &counter->attr_bytes_written);
+		goto cleanup_sysfs_read;
+	ret = sysfs_create_file(pdd->kobj_ais,
+				&new_counter->attr_bytes_written);
+	if (ret)
+		goto cleanup_attr_write;
 
-out:
-	xa_unlock(&pdd->ais_counters_xa);
 	return 0;
+
+cleanup_attr_write:
+	kfree(new_counter->attr_bytes_written.name);
+cleanup_sysfs_read:
+	sysfs_remove_file(pdd->kobj_ais, &new_counter->attr_bytes_read);
+cleanup_attr_read:
+	kfree(new_counter->attr_bytes_read.name);
+cleanup_entry:
+	xa_lock(&pdd->ais_counters_xa);
+	xa_erase(&pdd->ais_counters_xa, pdev->devfn);
+	xa_unlock(&pdd->ais_counters_xa);
+	kvfree(new_counter);
+	return ret;
 }
 #endif /* HAVE_STRUCT_XARRAY */
 
-- 
2.43.0


From 32c73065cace150dd576721e1316813d6b17947f Mon Sep 17 00:00:00 2001
From: Amir Shetaia <amir.shetaia@amd.com>
Date: Tue, 24 Feb 2026 15:37:21 -0500
Subject: [PATCH 2/2] drm/amdkfd: Add P2P distance caching with composite
 xarray keys

Add P2P distance caching in the AIS path using composite xarray keys to
eliminate redundant PCI hierarchy traversals during high-IOPS workloads.
The P2P distance between a GPU and storage device pair is invariant at
runtime, making it ideal for caching.

The implementation uses composite keys encoding domain:bus:devfn in a 32-bit
value to ensure device uniqueness across the system:
  Key format: [domain(16-bit)][bus(8-bit)][devfn(8-bit)]

This prevents devfn collisions between devices on different PCI buses.
A counter entry is created for each peer device right after
pci_p2pdma_distance() passes. On subsequent I/O operations, the entry's
existence alone indicates P2P accessibility, skipping the expensive
distance check.

Signed-off-by: Amir Shetaia <amir.shetaia@amd.com>
---
 drivers/gpu/drm/amd/amdkfd/kfd_ais.c | 70 ++++++++++++++++++++++++----
 1 file changed, 61 insertions(+), 9 deletions(-)

diff --git a/drivers/gpu/drm/amd/amdkfd/kfd_ais.c b/drivers/gpu/drm/amd/amdkfd/kfd_ais.c
index 82b6d351fd0f..4a02eeb6ce10 100644
--- a/drivers/gpu/drm/amd/amdkfd/kfd_ais.c
+++ b/drivers/gpu/drm/amd/amdkfd/kfd_ais.c
@@ -196,6 +196,23 @@ static int kfd_ais_init_attr(struct attribute *attr, struct pci_dev *pdev, bool
 	return 0;
 }
 
+/**
+ * kfd_ais_make_key() - Create unique xarray key for PCI device
+ * @pdev: PCI device
+ *
+ * Returns: Composite key encoding domain:bus:devfn
+ *
+ * Format: [domain(16-bit)][bus(8-bit)][devfn(8-bit)] = 32-bit value
+ * This ensures xarray entries are unique across the entire system.
+ */
+static unsigned long kfd_ais_make_key(struct pci_dev *pdev)
+{
+	int domain = pci_domain_nr(pdev->bus);
+	int bus = pdev->bus->number;
+
+	return ((unsigned long)domain << 16) | ((unsigned long)bus << 8) | pdev->devfn;
+}
+
 static int kfd_ais_update_counters(uint64_t size_copied, struct pci_dev *pdev,
 				    struct kfd_process_device *pdd, bool is_read)
 {
@@ -205,7 +222,8 @@ static int kfd_ais_update_counters(uint64_t size_copied, struct pci_dev *pdev,
 
 	/* Fast path: update existing counter */
 	xa_lock(&pdd->ais_counters_xa);
-	counter = (struct ais_counter_entry *)xa_load(&pdd->ais_counters_xa, pdev->devfn);
+	counter = (struct ais_counter_entry *)xa_load(&pdd->ais_counters_xa,
+						      kfd_ais_make_key(pdev));
 	if (counter) {
 		if (is_read)
 			counter->bytes_read += size_copied;
@@ -229,15 +247,16 @@ static int kfd_ais_update_counters(uint64_t size_copied, struct pci_dev *pdev,
 
 	/* Insert entry atomically */
 	xa_lock(&pdd->ais_counters_xa);
-	ret = __xa_insert(&pdd->ais_counters_xa, pdev->devfn, new_counter,
-			  GFP_ATOMIC);
+	ret = __xa_insert(&pdd->ais_counters_xa, kfd_ais_make_key(pdev),
+			  new_counter, GFP_ATOMIC);
 	xa_unlock(&pdd->ais_counters_xa);
 
 	if (ret == -EBUSY) {
 		/* Race: another thread created it - update and free ours */
 		kvfree(new_counter);
 		xa_lock(&pdd->ais_counters_xa);
-		counter = xa_load(&pdd->ais_counters_xa, pdev->devfn);
+		counter =
+			xa_load(&pdd->ais_counters_xa, kfd_ais_make_key(pdev));
 		if (counter) {
 			if (is_read)
 				counter->bytes_read += size_copied;
@@ -274,11 +293,36 @@ static int kfd_ais_update_counters(uint64_t size_copied, struct pci_dev *pdev,
 	kfree(new_counter->attr_bytes_read.name);
 cleanup_entry:
 	xa_lock(&pdd->ais_counters_xa);
-	xa_erase(&pdd->ais_counters_xa, pdev->devfn);
+	xa_erase(&pdd->ais_counters_xa, kfd_ais_make_key(pdev));
 	xa_unlock(&pdd->ais_counters_xa);
 	kvfree(new_counter);
 	return ret;
 }
+
+/**
+ * kfd_ais_check_p2p_cached() - Check if P2P distance already validated
+ * @pdd: Process device data
+ * @pdev: PCI device
+ *
+ * Returns: true if P2P already validated (skip distance check), false otherwise
+ *
+ * If an entry exists in ais_counters_xa for this device, pci_p2pdma_distance()
+ * has already passed for it. The entry is created right after a successful
+ * distance check, so its existence alone indicates P2P accessibility.
+ *
+ * The xarray is keyed by composite domain:bus:devfn to ensure uniqueness.
+ */
+static bool kfd_ais_check_p2p_cached(struct kfd_process_device *pdd,
+				     struct pci_dev *pdev)
+{
+	return xa_load(&pdd->ais_counters_xa, kfd_ais_make_key(pdev)) != NULL;
+}
+#else
+static bool kfd_ais_check_p2p_cached(struct kfd_process_device *pdd,
+				     struct pci_dev *pdev)
+{
+	return false;
+}
 #endif /* HAVE_STRUCT_XARRAY */
 
 int kfd_ais_rw_file(struct amdgpu_device *adev, struct amdgpu_bo *bo,
@@ -312,10 +356,18 @@ int kfd_ais_rw_file(struct amdgpu_device *adev, struct amdgpu_bo *bo,
 		goto out;
 	}
 
-	if (pci_p2pdma_distance(pdev, adev->dev, false) < 0) {
-		dev_info(adev->dev, "DMA-BUF p2p not accessible!\n");
-		ret = -ENODEV;
-		goto out;
+	/* Check if P2P already validated; on miss, check and create entry */
+	if (!kfd_ais_check_p2p_cached(pdd, pdev)) {
+		if (pci_p2pdma_distance(pdev, adev->dev, false) < 0) {
+			dev_info(adev->dev, "DMA-BUF p2p not accessible!\n");
+			ret = -ENODEV;
+			goto out;
+		}
+		/* P2P accessible - create counter entry so future calls skip
+		 * the distance check. Counter values start at 0 and get
+		 * updated after successful transfers.
+		 */
+		kfd_ais_update_counters(0, pdev, pdd, is_read);
 	}
 
 	if (WARN_ON(bo->preferred_domains != AMDGPU_GEM_DOMAIN_VRAM)) {
-- 
2.43.0

