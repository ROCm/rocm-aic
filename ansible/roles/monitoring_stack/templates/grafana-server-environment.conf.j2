# Managed by Ansible (monitoring_stack).
[Service]
Environment="GF_AUTH_ANONYMOUS_ENABLED=true"
Environment="GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer"
Environment="GF_USERS_ALLOW_SIGN_UP=false"
{% if monitoring_grafana_admin_password is defined and monitoring_grafana_admin_password | string | length > 0 %}
Environment="GF_SECURITY_ADMIN_USER={{ monitoring_grafana_admin_user | default('admin') }}"
Environment="GF_SECURITY_ADMIN_PASSWORD={{ monitoring_grafana_admin_password }}"
{% endif %}
