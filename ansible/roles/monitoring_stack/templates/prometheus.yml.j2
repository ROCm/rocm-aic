# Managed by Ansible (monitoring_stack). Do not edit on host.
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: rocm-icms
    replica: "{{ inventory_hostname }}"

rule_files:
  - /etc/prometheus/rules/rocm_icms.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - localhost:9090

{% if groups['gpu_nodes'] | default([]) | length > 0 %}
  - job_name: node_exporter
    static_configs:
{% for host in groups['gpu_nodes'] %}
      - targets:
          - "{{ hostvars[host].ansible_host }}:9100"
        labels:
          instance: "{{ host }}"
{% endfor %}

  - job_name: nvme_exporter
    static_configs:
{% for host in groups['gpu_nodes'] %}
      - targets:
          - "{{ hostvars[host].ansible_host }}:{{ (hostvars[host].nvme_exporter_listen_address | default(nvme_exporter_listen_address | default(':9998'))) | regex_replace('^.*:', '') }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  - job_name: rdma_exporter
    static_configs:
{% for host in groups['gpu_nodes'] %}
      - targets:
          - "{{ hostvars[host].ansible_host }}:{{ (hostvars[host].rdma_exporter_listen_address | default(':9879')) | regex_replace('^.*:', '') }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  # Dashboard 23434 and label_values(hostname) expect a hostname label on GPU
  # series. The exporter may omit it or use the OS short name; attach the
  # inventory hostname here so multi-node views and legends match Ansible.
  - job_name: amd_metrics_exporter
    metrics_path: /metrics
    static_configs:
{% for host in groups['gpu_nodes'] %}
      - targets:
          - "{{ hostvars[host].ansible_host }}:{{ hostvars[host].rocm_setup_metrics_exporter_port | default(rocm_setup_metrics_exporter_port | default(5000)) }}"
        labels:
          instance: "{{ host }}"
          hostname: "{{ host }}"
{% endfor %}
{% endif %}

{% if monitoring_llmd_prometheus_federate_enabled | default(false) | bool %}
  - job_name: llmd_federate
    honor_labels: true
    scrape_interval: 30s
    metrics_path: /federate
    params:
      'match[]':
{% for m in monitoring_llmd_federate_match %}
        - "{{ m }}"
{% endfor %}
    scheme: "{{ monitoring_llmd_prometheus_federate_scheme | default('https') }}"
{% if monitoring_llmd_prometheus_federate_ca_file | default('') | length > 0 %}
    tls_config:
      ca_file: "{{ monitoring_llmd_prometheus_federate_ca_file }}"
{% elif monitoring_llmd_prometheus_federate_insecure_skip_verify | default(false) | bool %}
    tls_config:
      insecure_skip_verify: true
{% endif %}
    static_configs:
      - targets:
          - "{{ monitoring_llmd_prometheus_federate_host }}"
{% endif %}
