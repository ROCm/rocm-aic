[Unit]
Description=ROCm AIC Prometheus textfile exporter
After=network-online.target local-fs.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=ROCM_AIC_EXPORTER_TEXTFILE={{ host_setup_rocm_aic_exporter_textfile_path }}
Environment=ROCM_ICMS_TEXTFILE_DIR={{ host_setup_node_exporter_textfile_dir }}
Environment=VLH_HOST_DATA_ROOT={{ host_setup_rocm_aic_exporter_vlh_host_data_root }}
Environment=VLH_LMCACHE_KV_SUBDIR={{ host_setup_rocm_aic_exporter_lmcache_kv_subdir }}
Environment=VLH_LMCACHE_CHUNK_STATS_SUBDIR={{ host_setup_rocm_aic_exporter_lmcache_chunk_stats_subdir }}
Environment=ROCM_AIC_KFD_AIS_SAMPLE_SECONDS={{ host_setup_rocm_aic_exporter_kfd_ais_sample_seconds }}
{% if host_setup_rocm_aic_exporter_ais_stats_container | default('') | length > 0 %}
Environment=ROCM_AIC_AIS_STATS_CONTAINER={{ host_setup_rocm_aic_exporter_ais_stats_container }}
Environment=ROCM_AIC_AIS_STATS_ENGINE_MATCH={{ host_setup_rocm_aic_exporter_ais_stats_engine_match }}
{% endif %}
ExecStart=/usr/bin/python3 {{ host_setup_rocm_aic_exporter_install_dir }}/rocm-aic-exporter.py \
  --prometheus-textfile \
  --textfile-only
