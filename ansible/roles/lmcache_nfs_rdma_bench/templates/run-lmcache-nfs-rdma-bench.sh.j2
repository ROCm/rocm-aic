set -euo pipefail

RESULTS_DIR={{ lmcache_io_tester_results_resolved | quote }}
INSTALL_DIR={{ lmcache_io_tester_install_dir | quote }}
VENV_PY="{{ lmcache_io_tester_venv }}/bin/python"
DATA_DIR={{ lmcache_io_tester_data_dir | quote }}
NFS_MOUNT={{ nfs_rdma_client_mount | quote }}
INTERVAL={{ lmcache_nfs_rdma_sample_interval_sec | int }}
RETRIEVE_SEC={{ lmcache_nfs_rdma_retrieve_duration_sec | int }}
VERBOSE_LM="{{ lmcache_nfs_rdma_verbose_lmcache | bool | lower }}"
INCLUDE_RETRIEVE="{{ lmcache_nfs_rdma_include_retrieve_only | bool | lower }}"
RETRIEVE_WORKERS={{ lmcache_nfs_rdma_parallel_retrieve_workers | default(1) | int }}
PIP_FREEZE="{{ lmcache_nfs_rdma_run_pip_freeze | bool | lower }}"
SERVER_IP={{ nfs_rdma_server_ip | default('') | quote }}
EXPORT_PATH={{ nfs_rdma_export_path | default('') | quote }}

mkdir -p "${RESULTS_DIR}"
cd "${INSTALL_DIR}"

rdma_snapshot() {
  local out="$1"
  if command -v rdma >/dev/null 2>&1; then
    {
      echo "=== rdma statistic show ==="
      rdma statistic show 2>&1 || true
      echo "=== rdma link show ==="
      rdma link show 2>&1 || true
      echo "=== rdma dev show ==="
      rdma dev show 2>&1 || true
    } > "${out}"
  else
    echo "rdma CLI not found" > "${out}"
    if command -v ibstat >/dev/null 2>&1; then
      ibstat >> "${out}" 2>&1 || true
    fi
  fi
}

nfsiostat_baseline() {
  local out="$1"
  if ! command -v nfsiostat >/dev/null 2>&1; then
    echo "nfsiostat not found" > "${out}"
    return
  fi
  nfsiostat "${NFS_MOUNT}" 1 2 > "${out}" 2>&1 || \
    nfsiostat 1 2 > "${out}" 2>&1 || \
    nfsiostat > "${out}" 2>&1 || true
}

write_context() {
  {
    echo "=== findmnt ==="
    findmnt -n "${NFS_MOUNT}" 2>&1 || true
    echo "=== nfsstat -m ==="
    nfsstat -m 2>&1 || true
    echo "=== /proc/mounts (nfs line) ==="
    grep -E " nfs4? " /proc/mounts 2>&1 | grep -F "${NFS_MOUNT}" || true
  } > "${RESULTS_DIR}/mount.txt"

  {
    echo "nfs_rdma_server_ip=${SERVER_IP}"
    echo "nfs_rdma_export_path=${EXPORT_PATH}"
    echo "nfs_rdma_client_mount=${NFS_MOUNT}"
    echo "data_dir=${DATA_DIR}"
  } > "${RESULTS_DIR}/nfs-export.txt"

  uname -a > "${RESULTS_DIR}/uname.txt"
  "${VENV_PY}" --version > "${RESULTS_DIR}/python-version.txt" 2>&1 || true

  if [[ "${PIP_FREEZE}" == "true" ]]; then
    "${VENV_PY}" -m pip freeze > "${RESULTS_DIR}/pip-freeze.txt" 2>&1 || true
  fi

  df -h "${NFS_MOUNT}" > "${RESULTS_DIR}/df-mount.txt" 2>&1 || true
  nfsstat -cn > "${RESULTS_DIR}/nfsstat-client-before.txt" 2>&1 || true
}

VERBOSE_ARGS=()
export LMCACHE_SIM_VERBOSE_LMCACHE=0
if [[ "${VERBOSE_LM}" == "true" ]]; then
  VERBOSE_ARGS+=(--verbose-lmcache)
  export LMCACHE_SIM_VERBOSE_LMCACHE=1
fi

run_lmcache() {
  "${VENV_PY}" -m src.lmcache-sim run "${VERBOSE_ARGS[@]}" "$@"
}

run_workload() {
  run_lmcache \
    --storage-type filesystem \
    --storage-path "${DATA_DIR}" \
    --pattern store-only \
    --num-operations 65536
  sleep 3
  run_lmcache \
    --storage-type filesystem \
    --storage-path "${DATA_DIR}" \
    --pattern lookup-only \
    --duration 60
  sleep 3
  if [[ "${INCLUDE_RETRIEVE}" == "true" ]]; then
    if (( RETRIEVE_WORKERS <= 1 )); then
      run_lmcache \
        --storage-type filesystem \
        --storage-path "${DATA_DIR}" \
        --pattern retrieve-only \
        --duration "${RETRIEVE_SEC}"
    else
      echo "=== parallel retrieve-only: ${RETRIEVE_WORKERS} workers (same DATA_DIR) ==="
      pr_base="${RESULTS_DIR}/parallel-retrieve"
      mkdir -p "${pr_base}"
      echo "parallel_retrieve_workers=${RETRIEVE_WORKERS}" >> "${RESULTS_DIR}/summary.txt"
      pids=()
      for ((wi = 1; wi <= RETRIEVE_WORKERS; wi++)); do
        wdir="${pr_base}/w${wi}"
        mkdir -p "${wdir}"
        (
          run_lmcache \
            --storage-type filesystem \
            --storage-path "${DATA_DIR}" \
            --pattern retrieve-only \
            --duration "${RETRIEVE_SEC}" \
            --per-op-log "${wdir}/retrieve-only.jsonl"
        ) >"${wdir}/run.log" 2>&1 &
        pids+=($!)
      done
      pr_rc=0
      for pid in "${pids[@]}"; do
        if ! wait "${pid}"; then
          pr_rc=1
        fi
      done
      echo "=== parallel retrieve finished (aggregate_exit=${pr_rc}) ==="
      for ((wi = 1; wi <= RETRIEVE_WORKERS; wi++)); do
        echo ""
        echo "--- worker w${wi} (stdout/stderr) ---"
        cat "${pr_base}/w${wi}/run.log"
      done
      if (( pr_rc != 0 )); then
        echo "parallel retrieve: one or more workers failed (see ${pr_base}/w*/run.log)" >&2
        return "${pr_rc}"
      fi
    fi
    sleep 3
  fi
}

NFSIOSTAT_PID=""
RDMA_LOOP_PID=""

cleanup() {
  set +e
  if [[ -n "${NFSIOSTAT_PID}" ]] && kill -0 "${NFSIOSTAT_PID}" 2>/dev/null; then
    kill "${NFSIOSTAT_PID}" 2>/dev/null || true
    wait "${NFSIOSTAT_PID}" 2>/dev/null || true
  fi
  if [[ -n "${RDMA_LOOP_PID}" ]] && kill -0 "${RDMA_LOOP_PID}" 2>/dev/null; then
    kill "${RDMA_LOOP_PID}" 2>/dev/null || true
    wait "${RDMA_LOOP_PID}" 2>/dev/null || true
  fi
  set -e
  rdma_snapshot "${RESULTS_DIR}/rdma-after.txt"
  nfsiostat_baseline "${RESULTS_DIR}/nfsiostat-after.txt"
  nfsstat -cn > "${RESULTS_DIR}/nfsstat-client-after.txt" 2>&1 || true
}
trap cleanup EXIT

write_context
rdma_snapshot "${RESULTS_DIR}/rdma-before.txt"
nfsiostat_baseline "${RESULTS_DIR}/nfsiostat-baseline.txt"

if command -v nfsiostat >/dev/null 2>&1; then
  (
    nfsiostat "${NFS_MOUNT}" "${INTERVAL}" 2>&1 || nfsiostat "${INTERVAL}" 2>&1
  ) >> "${RESULTS_DIR}/nfsiostat.stream.log" &
  NFSIOSTAT_PID=$!
fi

(
  while true; do
    echo "===== $(date -Is) =====" >> "${RESULTS_DIR}/rdma-statistic.sample.log"
    if command -v rdma >/dev/null 2>&1; then
      rdma statistic show >> "${RESULTS_DIR}/rdma-statistic.sample.log" 2>&1 \
        || echo "(rdma statistic show failed)" >> "${RESULTS_DIR}/rdma-statistic.sample.log"
    else
      echo "(no rdma CLI)" >> "${RESULTS_DIR}/rdma-statistic.sample.log"
    fi
    sleep "${INTERVAL}"
  done
) &
RDMA_LOOP_PID=$!

mkdir -p "${DATA_DIR}"
set -o pipefail
run_workload 2>&1 | tee "${RESULTS_DIR}/lmcache-run.log"
WORKLOAD_RC=${PIPESTATUS[0]}
echo "lmcache_workload_exit_code=${WORKLOAD_RC}" >> "${RESULTS_DIR}/summary.txt"
exit "${WORKLOAD_RC}"
