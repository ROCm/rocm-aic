---- RDMA connectivity ({{ rdma_network_matrix_mode | default('full_ping') }})  ts={{ rdma_network_report_ts }}  hosts={{ rdma_network_host_list | default([]) | join(', ') }}  log_host={{ inventory_hostname }}{% if (rdma_network_random_subset_count | default(0) | int) > 0 %}  random_subset_N={{ rdma_network_random_subset_count | int }}  icmp_plan={{ rdma_network_icmp_mesh_plan_total | default('?') }}  perftest_plan={{ rdma_network_perftest_mesh_plan_total | default('?') }}{% endif %} ----
{% set pings = rdma_network_ping_results | default([]) %}
{% set links = rdma_network_link_results | default([]) %}
{% if pings | length > 0 %}
ICMP (fabric: src NIC to dst NIC; ping -I when src IP set)
RESULT  |  HOSTS  |  SRC_IP  |  DST_IP  |  SRC_NETDEV  |  DST_NETDEV
--------------------------------------------------------------------------------
{% for p in pings %}
{% set rc = p.return_code | default(-1) | int %}
{% set st = 'PASS' if rc == 0 else 'FAIL' %}
{% set pair = (p.source_host | default('')) ~ ' -> ' ~ (p.target_host | default('')) %}
{{ st }}  |  {{ pair | truncate(28, True, '') }}  |  {{ p.ping_source_ip | default('', true) | string | truncate(18, True, '') }}  |  {{ p.ping_destination | default('', true) | string | truncate(18, True, '') }}  |  {{ p.server_netdev | default('', true) | string | truncate(14, True, '') }}  |  {{ p.client_netdev | default('', true) | string | truncate(14, True, '') }}
{% endfor %}
{% set pass_icmp = pings | selectattr('return_code', 'defined') | map(attribute='return_code') | map('int') | select('equalto', 0) | list | length %}
ICMP: PASS={{ pass_icmp }} FAIL={{ (pings | length) - pass_icmp }} TOTAL={{ pings | length }}
{% elif (rdma_network_matrix_mode | default('full_ping')) == 'full_ping' %}
ICMP: (no ping rows)
{% endif %}
{% if links | length > 0 %}
PERFTEST
RESULT  |  SERVER (dev @ IP) -> CLIENT (dev @ IP)  |  RC
--------------------------------------------------------------------------------
{% for L in links %}
{% set crc = L.client_exit_code | default(-1) | int %}
{% set st = 'PASS' if crc == 0 else 'FAIL' %}
{% set edge = (L.server_inventory_hostname | default('')) ~ ':' ~ (L.server_rdma_device | default('')) ~ '@' ~ (L.server_ipv4 | default('')) ~ ' -> ' ~ (L.client_inventory_hostname | default('')) ~ ':' ~ (L.client_rdma_device | default('')) ~ '@' ~ (L.client_ipv4 | default('')) %}
{{ st }}  |  {{ edge | truncate(90, True, '') }}  |  {{ crc }}
{% endfor %}
{% set pass_pf = links | selectattr('client_exit_code', 'defined') | map(attribute='client_exit_code') | map('int') | select('equalto', 0) | list | length %}
PERFTEST: PASS={{ pass_pf }} FAIL={{ (links | length) - pass_pf }} TOTAL={{ links | length }}
{% elif (rdma_network_matrix_mode | default('full_ping')) in ['full_perftest', 'pair_pingpong'] %}
PERFTEST: (no link rows)
{% endif %}
---- end ----
