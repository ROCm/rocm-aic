apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

# Note: paths are relative to the result folder where the final yaml is assembled
# typically `results/sweeps/<sweep_name>/run-<run_id>/manifests`

# Use the LMCache flavor from tiered-prefix-cache
resources:
  - ../../../../../../tiered-prefix-cache/manifests/vllm/flavors/lmcache

# Apply components for additional functionality
components:
  - ../../../../../../tiered-prefix-cache/manifests/vllm/components/hostpath-models
  - ../../../../../../tiered-prefix-cache/manifests/vllm/components/hipfile
  - ../../../../../../host-configs/bnxt-re

# This must be present for the benchmark harness to replace the config-map automatically
configMapGenerator:
  - name: config-map
    behavior: replace
    literals:
      - |
        lmcache_config.yaml=chunk_size: 256

# Benchmark harness injects vLLM args and LMCache connector out of bench sweep declaration
patches:
  - target:
      kind: Deployment
      name: decode
    patch: |-
      - op: replace
        path: /spec/replicas
        value: {{replicas}}
      - op: replace
        path: /spec/template/spec/containers/0/image
        value: {{image}}
      - op: replace
        path: /spec/template/spec/containers/0/args
        value:
          - "{{model}}"
          - "--port=8000"
          - "--disable-access-log-for-endpoints=/health,/metrics,/v1/models"
          - "--tensor-parallel-size={{tensor_parallel_size}}"
          {{ENGINE_ARGS_ARRAY}}
      # Inject environment variables from sweep config
      {{ENV_VARS_PATCH}}
      - op: add
        path: /spec/template/spec/containers/0/env/-
        value:
          name: ROCR_VISIBLE_DEVICES
          value: "{{gpu_visible_ids}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/amd.com~1gpu
        value: "{{gpu_reservation_count}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/amd.com~1gpu
        value: "{{gpu_reservation_count}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/cpu
        value: "{{cpu}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/cpu
        value: "{{cpu}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/memory
        value: {{memory}}
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/memory
        value: {{memory}}
      # Add init container to clean up output directory
      - op: add
        path: /spec/template/spec/initContainers
        value:
          - name: cleanup-output
            image: busybox:latest
            command: ["/bin/sh", "-c"]
            args:
              - |
                echo "Cleaning up previous run output..."
                if [ -d /hipfile-of ]; then
                  rm -rf /hipfile-of/*
                  echo "Cleaned /hipfile-of"
                fi
                echo "Cleanup complete"
            volumeMounts:
              - name: hipfile-of
                mountPath: /hipfile-of
            securityContext:
              runAsUser: 0
              runAsGroup: 0
              allowPrivilegeEscalation: false