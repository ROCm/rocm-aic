{
    "filetype": "generate_conversations",
    "num_conversations": 256,
    "text_files": ["/inputs/gutenberg_combined.txt"],
    "print_stats": true,

    "prompt_input": {
        "num_turns": {
            "distribution": "lognormal",
            "average": 35,
            "median_ratio": 0.75,
            "max": 400
        },

        "common_prefix_num_tokens": {
            "distribution": "constant",
            "value": 12000
        },

        "prefix_num_tokens": {
            "distribution": "lognormal",
            "average": 8000,
            "median_ratio": 0.80,
            "max": 12000
        },

        "num_tokens": {
            "distribution": "lognormal",
            "average": 400,
            "median_ratio": 0.65,
            "max": 8000
        }
    },

    "prompt_output": {
        "num_tokens": {
            "distribution": "lognormal",
            "average": 280,
            "median_ratio": 0.60,
            "max": 3000
        }
    }
}
