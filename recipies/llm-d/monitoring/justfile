# Justfile for monitoring stack management
# Handles Grafana dashboard installation and monitoring setup

# Import common utilities
import? "../setup/justfile"
import? "../../common/llm-d/monitoring.justfile"

# Monitoring namespace
MONITORING_NAMESPACE := env_var_or_default('MONITORING_NAMESPACE', 'llm-d-monitoring')

# Path to llm-d submodule
LLM_D_PATH := "../../../submodules/llm-d"

# Default recipe - show available commands
default:
    @just --list

# Load all Grafana dashboards (llm-d + rocm-aic custom)
load-dashboards:
    @echo "📊 Loading Grafana dashboards..."
    @./load-dashboards.sh {{MONITORING_NAMESPACE}}
    @echo ""
    @echo "✅ Dashboards loaded into namespace: {{MONITORING_NAMESPACE}}"
    @echo "   Access Grafana at: http://localhost:3000 (after port-forward)"

# Load only llm-d default dashboards
load-llm-d-dashboards:
    @echo "📊 Loading llm-d default dashboards..."
    @{{LLM_D_PATH}}/docs/monitoring/scripts/load-llm-d-dashboards.sh {{MONITORING_NAMESPACE}}

# Load only rocm-aic custom dashboards
load-custom-dashboards:
    @echo "📊 Loading rocm-aic custom dashboards..."
    #!/usr/bin/env bash
    set -euo pipefail
    DASHBOARDS_DIR="./grafana/dashboards"
    NAMESPACE="{{MONITORING_NAMESPACE}}"

    if [ ! -d "$DASHBOARDS_DIR" ]; then
        echo "No custom dashboards directory found"
        exit 0
    fi

    dashboard_count=$(find "$DASHBOARDS_DIR" -maxdepth 1 -name "*.json" -type f 2>/dev/null | wc -l)

    if [ "$dashboard_count" -eq 0 ]; then
        echo "No custom dashboards found in $DASHBOARDS_DIR"
        exit 0
    fi

    echo "Loading $dashboard_count custom dashboard(s)..."

    for dashboard_file in "$DASHBOARDS_DIR"/*.json; do
        if [ ! -f "$dashboard_file" ]; then
            continue
        fi

        dashboard_name=$(basename "$dashboard_file" .json)
        configmap_name="rocm-aic-${dashboard_name}"

        echo "  - $dashboard_name"

        kubectl create configmap "${configmap_name}" \
            --from-file="${dashboard_name}.json=${dashboard_file}" \
            --namespace="${NAMESPACE}" \
            --dry-run=client -o yaml | \
        kubectl label -f - \
            grafana_dashboard=1 \
            --local --dry-run=client -o yaml | \
        kubectl apply -f -
    done

    echo "✅ Custom dashboards loaded"

# List loaded dashboards
list-dashboards:
    @echo "📊 Loaded Grafana dashboards in namespace: {{MONITORING_NAMESPACE}}"
    @echo ""
    @echo "llm-d dashboards (prefix: llmd-):"
    @kubectl get configmap -n {{MONITORING_NAMESPACE}} -l grafana_dashboard=1 | grep "^llmd-" || echo "  (none)"
    @echo ""
    @echo "rocm-aic dashboards (prefix: rocm-aic-):"
    @kubectl get configmap -n {{MONITORING_NAMESPACE}} -l grafana_dashboard=1 | grep "^rocm-aic-" || echo "  (none)"

# Delete all dashboards
delete-dashboards:
    @echo "🗑️  Deleting Grafana dashboards..."
    @echo "llm-d dashboards:"
    -kubectl delete configmap -n {{MONITORING_NAMESPACE}} -l grafana_dashboard=1 --field-selector metadata.name=llmd-* 2>/dev/null || true
    @echo "rocm-aic dashboards:"
    -kubectl delete configmap -n {{MONITORING_NAMESPACE}} -l grafana_dashboard=1 --field-selector metadata.name=rocm-aic-* 2>/dev/null || true
    @echo "✅ Dashboards deleted"

# Reload dashboards (delete and reload)
reload-dashboards: delete-dashboards load-dashboards
    @echo "✅ Dashboards reloaded"

# Show Grafana access info
grafana-access:
    @echo "Grafana Access Information"
    @echo "=========================="
    @echo ""
    @echo "URL: http://localhost:3000 (after port-forward)"
    @echo "Username: admin"
    @echo -n "Password: "
    @kubectl get secret -n {{MONITORING_NAMESPACE}} llmd-grafana -o jsonpath='{.data.admin-password}' 2>/dev/null | base64 -d || echo "(Grafana not found)"
    @echo ""
    @echo ""
    @echo "To start port-forward from any deployment:"
    @echo "  just port-forward-start"

# Verify monitoring stack is running
verify-monitoring:
    @echo "🔍 Verifying monitoring stack..."
    @echo ""
    @echo "Prometheus:"
    @kubectl get pods -n {{MONITORING_NAMESPACE}} -l app.kubernetes.io/name=prometheus --no-headers | wc -l | xargs -I {} echo "  {} pod(s)"
    @echo "Grafana:"
    @kubectl get pods -n {{MONITORING_NAMESPACE}} -l app.kubernetes.io/name=grafana --no-headers | wc -l | xargs -I {} echo "  {} pod(s)"
    @echo ""
    @if kubectl get pods -n {{MONITORING_NAMESPACE}} -l app.kubernetes.io/name=prometheus --no-headers 2>/dev/null | grep -q Running; then \
        echo "✅ Monitoring stack is running"; \
    else \
        echo "❌ Monitoring stack not found or not running"; \
        echo "   Deploy monitoring stack from llm-d guides first"; \
    fi
