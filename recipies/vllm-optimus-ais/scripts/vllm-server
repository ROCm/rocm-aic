#!/usr/bin/env bash
# Copyright (c) Advanced Micro Devices, Inc. All rights reserved.
# SPDX-License-Identifier: MIT
#
# Container ENTRYPOINT for vllm-optimus-kvd.
#
# Two-stage startup:
#   1. rocserve.kvd daemon — UDS-served KV store, owns RAM+SSD tiers.
#   2. vllm serve — engine, points at the daemon via --kv-transfer-config.
#
# Env (all have sensible defaults; Makefile passes them through):
#   VLLM_MODEL                 model path / HF id
#   TENSOR_PARALLEL_SIZE       TP world size
#   MAX_MODEL_LEN              vLLM --max-model-len
#   GPU_MEMORY_UTILIZATION     vLLM --gpu-memory-utilization
#   KV_CACHE_MEMORY_BYTES      vLLM --kv-cache-memory-bytes (L1 cap)
#   PORT                       vLLM HTTP port
#   CONTAINER_DATA_DIR         kvd long+short tier root (e.g. /data)
#   CONTAINER_LOG_DIR          where to write kvd.log + vllm logs
#   ROCSERVE_KVD_LONG_BYTES    kvd --long-bytes
#   ROCSERVE_KVD_SHORT_BYTES   kvd --spillover-bytes
#   ROCSERVE_KVD_LAYERWISE_LOAD  off|stepped|prefetch|parallel
#   ROCSERVE_KVD_GPU_DIRECT      0|1|auto (auto = ais-check)
#   ROCSERVE_KVD_LOAD_WORKERS    parallel-load worker count
#   ROCSERVE_KVD_CHUNK_TARGET_MIB target chunk size, 128 = P2PDMA sweet spot
#   ROCSERVE_KVD_FSYNC_SAVE      ""|1 — crash-safe save publish (default off)
#   ARGS                       extra args appended to `vllm serve`
#
# This script `exec`s vllm serve at the end so signal forwarding works.

set -euo pipefail

# ---- defaults ----
: "${VLLM_MODEL:=openai/gpt-oss-120b}"
: "${TENSOR_PARALLEL_SIZE:=1}"
: "${MAX_MODEL_LEN:=131072}"
: "${GPU_MEMORY_UTILIZATION:=0.90}"
: "${KV_CACHE_MEMORY_BYTES:=85899345920}"   # 80 GiB
: "${PORT:=8000}"
: "${CONTAINER_DATA_DIR:=/data}"
: "${CONTAINER_LOG_DIR:=/var/log/vllm-optimus-kvd}"
: "${ROCSERVE_KVD_LONG_BYTES:=549755813888}"   # 512 GiB
: "${ROCSERVE_KVD_SHORT_BYTES:=68719476736}"   #  64 GiB
: "${ROCSERVE_KVD_LAYERWISE_LOAD:=parallel}"
: "${ROCSERVE_KVD_GPU_DIRECT:=auto}"
: "${ROCSERVE_KVD_LOAD_WORKERS:=8}"
: "${ROCSERVE_KVD_CHUNK_TARGET_MIB:=128}"
: "${ROCSERVE_KVD_FSYNC_SAVE:=}"
: "${ARGS:=}"

mkdir -p \
    "${CONTAINER_LOG_DIR}" \
    "${CONTAINER_DATA_DIR}/kvd-long" \
    "${CONTAINER_DATA_DIR}/kvd-short" \
    /run/rocserve-kvd

# ---- 0. hipfile python binding smoke-check (runtime — needs /dev/kfd) ----
# Skipped at docker build; verify here that the binding loads under the
# actual ROCm runtime. Failure here = the host is missing the amdgpu
# kernel module or /dev/kfd, not a build issue.
if ! python3 -c "from hipfile import Buffer; from hipfile._hipfile import hipFileBufRegister" 2>&1; then
    echo "ERROR: hipfile python binding failed to load — is /dev/kfd present + amdgpu loaded?" >&2
    echo "       ais-stats output:" >&2
    /app/ais-stats 2>&1 | head -10 >&2 || true
    exit 1
fi
echo "hipfile binding loaded OK" >&2

# ---- 1. kvd daemon ----
KVD_SOCK=/run/rocserve-kvd/kvd.sock
rm -f "$KVD_SOCK"

# cwd /tmp to avoid /app/vllm namespace-package shadowing.
cd /tmp
nohup python3 -m rocserve.kvd \
    --socket "$KVD_SOCK" \
    --max-bytes $((4 << 30)) \
    --long-path  "${CONTAINER_DATA_DIR}/kvd-long"  --long-bytes  "${ROCSERVE_KVD_LONG_BYTES}" \
    --spillover-path "${CONTAINER_DATA_DIR}/kvd-short" --spillover-bytes "${ROCSERVE_KVD_SHORT_BYTES}" \
    > "${CONTAINER_LOG_DIR}/kvd.log" 2>&1 &
KVD_PID=$!

# Wait for the UDS socket to appear so vllm doesn't race admission.
for i in {1..30}; do
    if grep -q "listening on" "${CONTAINER_LOG_DIR}/kvd.log" 2>/dev/null; then
        break
    fi
    sleep 2
done
if ! grep -q "listening on" "${CONTAINER_LOG_DIR}/kvd.log" 2>/dev/null; then
    echo "ERROR: kvd daemon did not become ready in 60 s" >&2
    tail -50 "${CONTAINER_LOG_DIR}/kvd.log" >&2 || true
    exit 1
fi
echo "kvd ready: PID=$KVD_PID socket=$KVD_SOCK" >&2

# ---- 2. Optimus connector env ----
export ROCSERVE_KVD_SOCKET="$KVD_SOCK"
export ROCSERVE_KVD_HIPFILE_ROOTS="long=${CONTAINER_DATA_DIR}/kvd-long,short=${CONTAINER_DATA_DIR}/kvd-short"
export ROCSERVE_KVD_LAYERWISE_LOAD
export ROCSERVE_KVD_GPU_DIRECT
export ROCSERVE_KVD_LOAD_WORKERS
export ROCSERVE_KVD_CHUNK_TARGET_MIB
export ROCSERVE_KVD_FSYNC_SAVE
# PYTHONHASHSEED is already 0 from the Dockerfile ENV.

KV_TRANSFER='{"kv_connector":"RocserveKvdConnector","kv_role":"kv_both","kv_connector_module_path":"rocserve.engine.vllm.kvd_connector"}'

# ---- 3. vllm serve (exec for clean signal handling) ----
echo "starting vllm serve: model=${VLLM_MODEL} TP=${TENSOR_PARALLEL_SIZE} port=${PORT}" >&2
exec vllm serve "${VLLM_MODEL}" \
    --tensor-parallel-size "${TENSOR_PARALLEL_SIZE}" \
    --port "${PORT}" --host 0.0.0.0 \
    --max-model-len "${MAX_MODEL_LEN}" \
    --gpu-memory-utilization "${GPU_MEMORY_UTILIZATION}" \
    --kv-cache-memory-bytes "${KV_CACHE_MEMORY_BYTES}" \
    --trust-remote-code \
    --kv-transfer-config "$KV_TRANSFER" \
    ${ARGS}
