@@ -0,0 +1,101 @@
+# SPDX-License-Identifier: Apache-2.0
+# Standard
+from typing import Any, Dict, List, Optional
+
+# First Party
+from lmcache.v1.config import LMCacheEngineConfig
+
+DISK_BACKEND_EXACT = frozenset({"GdsBackend"})
+DISK_BACKEND_PREFIXES = ("RemoteBackend-",)
+
+
+def is_disk_backend_name(name: str) -> bool:
+    """Return True if *name* is a disk persistence backend."""
+    if name in DISK_BACKEND_EXACT:
+        return True
+    return any(name.startswith(prefix) for prefix in DISK_BACKEND_PREFIXES)
+
+
+def detect_disk_storage_mode(config: LMCacheEngineConfig) -> Optional[str]:
+    """Infer active disk layout from engine config."""
+    if config.gds_path:
+        return "hipfile"
+    if config.remote_storage_plugins:
+        return "posix"
+    return None
+
+
+def apply_disk_storage_profile(
+    config: LMCacheEngineConfig,
+    mode: str,
+    *,
+    gds_path: Optional[str] = None,
+    fs_base_path: Optional[str] = None,
+    gds_backend: Optional[str] = None,
+) -> Dict[str, Any]:
+    """Mutate *config* to match vllm-lmcache-hipfile hipfile or posix LMCache profiles.
+
+    Matches ``scripts/vllm-server`` materialization: hipfile uses ``gds_path``
+    and hipFile extra_config; posix uses ``remote_storage_plugins: [fs]`` with
+    ``local_cpu`` enabled as a staging buffer for RemoteBackend.
+    """
+    normalized = mode.lower().strip()
+    if normalized not in ("hipfile", "posix"):
+        raise ValueError(
+            "mode must be 'hipfile' or 'posix', got %r" % mode,
+        )
+
+    profile: Dict[str, Any] = {"mode": normalized}
+
+    if normalized == "hipfile":
+        path = gds_path or config.gds_path
+        if not path:
+            raise ValueError(
+                "gds_path is required for hipfile mode "
+                "(set in LMCache config or POST /storage/mode JSON body)",
+            )
+        config.gds_path = path
+        profile["gds_path"] = path
+        config.remote_storage_plugins = None
+        config.local_cpu = False
+        if gds_backend is not None:
+            config.gds_backend = gds_backend
+        elif not getattr(config, "gds_backend", None):
+            config.gds_backend = "hipfile"
+        extra = dict(config.extra_config or {})
+        extra["use_hipfile"] = True
+        extra["use_cufile"] = False
+        extra["use_direct_io"] = True
+        extra.pop("remote_storage_plugin.fs.base_path", None)
+        config.extra_config = extra or None
+    else:
+        base = fs_base_path
+        if not base:
+            extra = config.extra_config or {}
+            base = extra.get("remote_storage_plugin.fs.base_path")
+        if not base:
+            raise ValueError(
+                "fs_base_path is required for posix mode "
+                "(extra_config.remote_storage_plugin.fs.base_path or JSON body)",
+            )
+        if not base.endswith("/"):
+            base = base.rstrip("/") + "/"
+        config.gds_path = None
+        config.remote_storage_plugins = ["fs"]
+        config.local_cpu = True
+        if config.max_local_cpu_size <= 0:
+            config.max_local_cpu_size = 5.0
+        profile["fs_base_path"] = base
+        extra = dict(config.extra_config or {})
+        extra["remote_storage_plugin.fs.base_path"] = base
+        extra["use_direct_io"] = True
+        extra.pop("use_hipfile", None)
+        extra.pop("use_cufile", None)
+        config.extra_config = extra
+
+    return profile
+
+
+def disk_backend_names(backend_names: List[str]) -> List[str]:
+    """Filter *backend_names* to disk backends only."""
+    return [n for n in backend_names if is_disk_backend_name(n)]
