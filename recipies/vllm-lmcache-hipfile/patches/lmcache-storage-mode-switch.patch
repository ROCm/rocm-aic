+# SPDX-License-Identifier: Apache-2.0
+# Third Party
+from fastapi import APIRouter
+from starlette.requests import Request
+from starlette.responses import JSONResponse
+
+# First Party
+from lmcache.logging import init_logger
+
+logger = init_logger(__name__)
+
+router = APIRouter()
+
+_MODE_NOTE = (
+    "KV chunks on disk are not portable between hipfile (GdsBackend) and "
+    "posix (RemoteBackend-fs); repopulate after switching."
+)
+
+
+def _get_storage_manager(request: Request):
+    """Return (storage_manager, error_response)."""
+    lmcache_adapter = request.app.state.lmcache_adapter
+    lmcache_engine = getattr(lmcache_adapter, "lmcache_engine", None)
+    if not lmcache_engine:
+        return None, JSONResponse(
+            content={
+                "error": "Storage mode API is unavailable",
+                "message": "LMCache engine not configured.",
+            },
+            status_code=503,
+        )
+    sm = lmcache_engine.storage_manager
+    if sm is None:
+        return None, JSONResponse(
+            content={
+                "error": "Storage mode API is unavailable",
+                "message": "StorageManager not initialized.",
+            },
+            status_code=503,
+        )
+    return sm, None
+
+
+@router.get("/storage/mode")
+async def get_storage_mode(request: Request):
+    """Return the active disk storage mode (hipfile or posix)."""
+    try:
+        sm, err = _get_storage_manager(request)
+        if err:
+            return err
+        mode = sm.get_disk_storage_mode()
+        return JSONResponse(
+            content={
+                "status": "success",
+                "mode": mode,
+                "backends": sm.list_backends(),
+                "note": _MODE_NOTE,
+            },
+        )
+    except Exception as e:
+        logger.exception("Failed to get storage mode")
+        return JSONResponse(
+            content={
+                "error": "Failed to get storage mode",
+                "message": str(e),
+            },
+            status_code=500,
+        )
+
+
+@router.post("/storage/mode")
+async def set_storage_mode(request: Request):
+    """Switch disk persistence between hipfile (GdsBackend) and posix (fs).
+
+    JSON body::
+
+        {
+          "mode": "hipfile" | "posix",
+          "gds_path": "/data/lmcache",       // hipfile, optional if configured
+          "fs_base_path": "/data/lmcache/",  // posix, optional if configured
+          "gds_backend": "hipfile"           // hipfile, optional
+        }
+    """
+    try:
+        sm, err = _get_storage_manager(request)
+        if err:
+            return err
+
+        try:
+            body = await request.json()
+        except Exception:
+            body = {}
+        if not isinstance(body, dict):
+            body = {}
+
+        mode = body.get("mode")
+        if not mode or not isinstance(mode, str):
+            return JSONResponse(
+                content={
+                    "error": "Missing parameter",
+                    "message": "mode is required ('hipfile' or 'posix')",
+                },
+                status_code=400,
+            )
+
+        gds_path = body.get("gds_path")
+        fs_base_path = body.get("fs_base_path")
+        gds_backend = body.get("gds_backend")
+        if gds_path is not None and not isinstance(gds_path, str):
+            return JSONResponse(
+                content={
+                    "error": "Invalid parameter",
+                    "message": "gds_path must be a string",
+                },
+                status_code=400,
+            )
+        if fs_base_path is not None and not isinstance(fs_base_path, str):
+            return JSONResponse(
+                content={
+                    "error": "Invalid parameter",
+                    "message": "fs_base_path must be a string",
+                },
+                status_code=400,
+            )
+
+        result = sm.switch_disk_storage_mode(
+            mode,
+            gds_path=gds_path,
+            fs_base_path=fs_base_path,
+            gds_backend=gds_backend if isinstance(gds_backend, str) else None,
+        )
+        result["note"] = _MODE_NOTE
+        return JSONResponse(content=result)
+    except ValueError as e:
+        return JSONResponse(
+            content={
+                "error": "Invalid storage mode request",
+                "message": str(e),
+            },
+            status_code=400,
+        )
+    except Exception as e:
+        logger.exception("Failed to set storage mode")
+        return JSONResponse(
+            content={
+                "error": "Failed to set storage mode",
+                "message": str(e),
+            },
+            status_code=500,
+        )
