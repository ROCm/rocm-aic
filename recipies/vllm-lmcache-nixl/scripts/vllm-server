from __future__ import annotations

import json
import os
import subprocess
import sys
import threading
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError as e:
    print("ERROR: PyYAML is required (import yaml).", file=sys.stderr)
    raise SystemExit(1) from e

import importlib.util

_script_dir = Path(__file__).resolve().parent


def _load_defaults_module():
    path = _script_dir / "vllm-lmcache-nixl-defaults.py"
    spec = importlib.util.spec_from_file_location("vllm_vln_defaults", path)
    if spec is None or spec.loader is None:
        raise ImportError(f"cannot load {path}")
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod


_defaults = _load_defaults_module()
container_data_root = _defaults.container_data_root
container_server_log_dir = _defaults.container_server_log_dir
_cfg_next_to_script = _script_dir / "configs"
_CONFIG_DIR = (
    _cfg_next_to_script
    if _cfg_next_to_script.is_dir()
    else _script_dir.parent / "configs"
)
_SERVICE_YAML = _CONFIG_DIR / "vllm-lmcache-nixl.yaml"


def _lmcache_io_mode() -> str:
    return os.environ.get("VLN_LMCACHE_IO", "nixl-posix").strip().lower()


def _ais_hipfile_io_mode(mode: str) -> bool:
    return mode in (
        "ais",
        "ais_mt",
        "ais-mt",
        "ais_batch",
        "ais-batch",
        "hipfile",
        "hip",
    )


def _nixl_ais_backend_for_mode(mode: str) -> str | None:
    if mode in ("ais_batch", "ais-batch"):
        return "AIS"
    if _ais_hipfile_io_mode(mode):
        return "AIS_MT"
    return None


def _truthy(name: str, default: str = "1") -> bool:
    v = os.environ.get(name, default).strip().lower()
    return v not in ("0", "false", "no", "off", "")


def _chunk_statistics_extra(data_root: Path) -> dict[str, object]:
    out_dir = str(data_root / "lmcache_chunk_stats")
    Path(out_dir).mkdir(parents=True, exist_ok=True)
    return {
        "chunk_statistics_file_output_dir": out_dir,
        "chunk_statistics_file_rotation_size": 104857600,
        "chunk_statistics_file_max_count": 100,
    }


def _apply_chunk_statistics_env(env: dict[str, str]) -> None:
    if not _truthy("VLN_LMCACHE_ENABLE_CHUNK_STATISTICS", "1"):
        return
    env["LMCACHE_ENABLE_CHUNK_STATISTICS"] = "true"
    env["LMCACHE_CHUNK_STATISTICS_AUTO_START_STATISTICS"] = "true"
    env["LMCACHE_CHUNK_STATISTICS_STRATEGY"] = os.environ.get(
        "VLN_LMCACHE_CHUNK_STATISTICS_STRATEGY", "file_hash"
    ).strip()
    env.setdefault("PYTHONHASHSEED", "0")


def _apply_kv_events_env(env: dict[str, str]) -> None:
    if not _truthy("VLN_LMCACHE_ENABLE_KV_EVENTS", "1"):
        return
    env["LMCACHE_ENABLE_KV_EVENTS"] = "true"


def _apply_lmcache_log_level(env: dict[str, str]) -> None:
    v = os.environ.get("VLN_LMCACHE_LOG_LEVEL", "").strip()
    env["LMCACHE_LOG_LEVEL"] = v if v else "INFO"


def _apply_pytorch_alloc_conf(env: dict[str, str]) -> None:
    v = os.environ.get("VLN_PYTORCH_ALLOC_CONF", "").strip()
    if not v:
        v = os.environ.get("VLLM_PYTORCH_ALLOC_CONF", "").strip()
    if v:
        env["PYTORCH_ALLOC_CONF"] = v


def _enforce_eager() -> bool:
    v = os.environ.get("VLN_ENFORCE_EAGER", "").strip().lower()
    if not v:
        v = os.environ.get("VLLM_ENFORCE_EAGER", "").strip().lower()
    if v in ("0", "false", "no", "off"):
        return False
    return True


def _enable_mfu_metrics(prof: dict[str, Any]) -> bool:
    v = os.environ.get("VLN_ENABLE_MFU_METRICS", "").strip().lower()
    if not v:
        v = os.environ.get("VLLM_ENABLE_MFU_METRICS", "").strip().lower()
    if v in ("0", "false", "no", "off"):
        return False
    if v in ("1", "true", "yes", "on"):
        return True
    return bool(prof.get("enable_mfu_metrics", True))


def _tee_thread(stream: Any, log_f: Any) -> None:
    for line in iter(stream.readline, b""):
        if not line:
            break
        log_f.write(line)
        log_f.flush()
        try:
            sys.stdout.buffer.write(line)
            sys.stdout.buffer.flush()
        except BrokenPipeError:
            break


def _lmcache_template_from_svc(svc: dict[str, Any]) -> Path | None:
    mode = _lmcache_io_mode()
    if mode in ("nixl-posix", "posix", "nixl"):
        key = "lmcache_nixl_posix"
    elif _ais_hipfile_io_mode(mode):
        key = "lmcache_nixl_ais"
    else:
        print(
            "ERROR: VLN_LMCACHE_IO must be nixl-posix, ais, ais_mt, or ais_batch "
            f"(got {mode!r}); see configs/vllm-lmcache-nixl.yaml",
            file=sys.stderr,
        )
        return None
    lmc_path = svc.get(key)
    if not isinstance(lmc_path, str) or not lmc_path.strip():
        print(
            f"ERROR: vllm-lmcache-nixl.yaml must define {key} (LMCache template path)",
            file=sys.stderr,
        )
        return None
    return Path(lmc_path)


def _materialize_lmcache_config(svc: dict[str, Any], data_root: Path) -> Path | None:
    paths = svc.get("lmcache_paths")
    if not isinstance(paths, dict):
        print(
            "ERROR: vllm-lmcache-nixl.yaml must define lmcache_paths as a mapping",
            file=sys.stderr,
        )
        return None

    src = _lmcache_template_from_svc(svc)
    if src is None:
        return None
    cfg = yaml.safe_load(src.read_text(encoding="utf-8"))
    if not isinstance(cfg, dict):
        print(f"ERROR: invalid LMCache config {src}", file=sys.stderr)
        return None

    cache_subdir = paths.get("subdir")
    if not isinstance(cache_subdir, str) or not cache_subdir.strip():
        print(
            "ERROR: lmcache_paths.subdir must be a non-empty string",
            file=sys.stderr,
        )
        return None

    nixl_path = (data_root / cache_subdir).resolve()
    nixl_path.mkdir(parents=True, exist_ok=True)
    mode = _lmcache_io_mode()

    extra = cfg.get("extra_config")
    if not isinstance(extra, dict):
        extra = {}
    extra["nixl_path"] = str(nixl_path)
    ais_backend = _nixl_ais_backend_for_mode(mode)
    if ais_backend is not None:
        extra["nixl_backend"] = ais_backend
    cfg["extra_config"] = extra

    buf_mb = os.environ.get("VLN_NIXL_BUFFER_SIZE", "").strip()
    if buf_mb:
        try:
            cfg["nixl_buffer_size"] = int(buf_mb) * 1024 * 1024
        except ValueError:
            print(
                f"WARN: invalid VLN_NIXL_BUFFER_SIZE={buf_mb!r} (MiB expected)",
                file=sys.stderr,
            )

    buf_dev = os.environ.get("VLN_NIXL_BUFFER_DEVICE", "").strip()
    if buf_dev:
        if _ais_hipfile_io_mode(mode) and buf_dev == "cpu":
            print(
                "WARN: VLN_NIXL_BUFFER_DEVICE=cpu with AIS hipFile may fall back to "
                "compat mode; use cuda (default in lmcache-nixl-ais.yml)",
                file=sys.stderr,
            )
        cfg["nixl_buffer_device"] = buf_dev

    pool_size = os.environ.get("VLN_NIXL_POOL_SIZE", "").strip()
    if pool_size:
        try:
            extra["nixl_pool_size"] = int(pool_size)
        except ValueError:
            print(
                f"WARN: invalid VLN_NIXL_POOL_SIZE={pool_size!r} (integer expected)",
                file=sys.stderr,
            )
    cfg["extra_config"] = extra

    if _ais_hipfile_io_mode(mode):
        buf_bytes = cfg.get("nixl_buffer_size")
        buf_dev_effective = cfg.get("nixl_buffer_device", "cpu")
        nixl_backend = extra.get("nixl_backend", "AIS_MT")
        if isinstance(buf_bytes, int) and buf_dev_effective == "cuda":
            buf_mib = buf_bytes // (1024 * 1024)
            pool = extra.get("nixl_pool_size")
            print(
                f"vllm-lmcache-nixl {nixl_backend}: nixl_buffer_device=cuda "
                f"nixl_buffer_size={buf_mib} MiB nixl_pool_size={pool!r} "
                f"(VRAM + ~{pool} NVMe fds at init)",
                file=sys.stderr,
            )
            if nixl_backend == "AIS":
                print(
                    "WARN: nixl_backend=AIS uses hipFile batch APIs; on ROCm "
                    "hipFile 0.2.x batch GetStatus is not implemented — prefer "
                    "VLN_LMCACHE_IO=ais (AIS_MT default) or ais_mt",
                    file=sys.stderr,
                )
            if buf_mib >= 1024:
                print(
                    "WARN: AIS VRAM buffer >= 1024 MiB can OOM on 16 GiB GPUs; "
                    "try VLN_NIXL_BUFFER_SIZE=512 VLN_GPU_MEMORY_UTILIZATION=0.85",
                    file=sys.stderr,
                )
            if isinstance(pool, int) and pool > 65536:
                print(
                    f"WARN: nixl_pool_size={pool} opens one FD per slot at init; "
                    "expect long startup and ensure VLN_DOCKER_NOFILE is high enough",
                    file=sys.stderr,
                )

    prior_json = os.environ.get("LMCACHE_EXTRA_CONFIG", "").strip()
    if prior_json:
        try:
            prior = json.loads(prior_json)
            if isinstance(prior, dict):
                merged = {**prior, **extra}
                cfg["extra_config"] = merged
        except json.JSONDecodeError:
            pass

    if _truthy("VLN_LMCACHE_ENABLE_CHUNK_STATISTICS", "1"):
        ec = cfg.get("extra_config")
        if not isinstance(ec, dict):
            ec = {}
        ec.update(_chunk_statistics_extra(data_root))
        cfg["extra_config"] = ec

    out = data_root / ".lmcache-vln-runtime.yaml"
    out.write_text(
        yaml.safe_dump(cfg, default_flow_style=False, sort_keys=False),
        encoding="utf-8",
    )
    return out


def _resolve_nixl_plugin_dir(prefix: str, nixl_cfg: dict[str, Any]) -> str:
    """Pick the first existing NIXL plugin directory (image ENV can be stale)."""
    candidates: list[str] = []
    cfg_dir = nixl_cfg.get("plugin_dir")
    if isinstance(cfg_dir, str) and cfg_dir.strip():
        candidates.append(cfg_dir.strip())
    env_dir = os.environ.get("NIXL_PLUGIN_DIR", "").strip()
    if env_dir:
        candidates.append(env_dir)
    candidates.extend(
        [
            f"{prefix}/lib/x86_64-linux-gnu/plugins",
            f"{prefix}/lib/x86_64-linux-gnu/nixl/plugins",
            f"{prefix}/lib/nixl/plugins",
        ]
    )
    seen: set[str] = set()
    for path in candidates:
        if path in seen:
            continue
        seen.add(path)
        if os.path.isdir(path):
            return path
    return candidates[0] if candidates else f"{prefix}/lib/x86_64-linux-gnu/plugins"


def _apply_nixl_runtime_env(env: dict[str, str], svc: dict[str, Any]) -> None:
    nixl_cfg = svc.get("nixl")
    if not isinstance(nixl_cfg, dict):
        return
    prefix = str(nixl_cfg.get("install_prefix", "/opt/nixl")).rstrip("/")
    ucx = str(nixl_cfg.get("ucx_prefix", "/opt/rocnixl-ucx")).rstrip("/")
    plugin_dir = _resolve_nixl_plugin_dir(prefix, nixl_cfg)
    env["NIXL_PLUGIN_DIR"] = plugin_dir
    prev = env.get("LD_LIBRARY_PATH", "")
    nixl_lib = f"{prefix}/lib/x86_64-linux-gnu"
    parts = [nixl_lib, f"{prefix}/lib", f"{ucx}/lib", prev]
    env["LD_LIBRARY_PATH"] = ":".join(p for p in parts if p)
    py_site = f"{prefix}/lib/python3/dist-packages"
    prev_py = env.get("PYTHONPATH", "")
    env["PYTHONPATH"] = (
        f"{py_site}:{prev_py}" if prev_py else py_site
    )


def main() -> int:
    if not os.environ.get("ROCR_VISIBLE_DEVICES", "").strip():
        print("Error: ROCR_VISIBLE_DEVICES not set", file=sys.stderr)
        return 1

    if not _SERVICE_YAML.is_file():
        print(f"ERROR: missing {_SERVICE_YAML}", file=sys.stderr)
        return 1

    svc = yaml.safe_load(_SERVICE_YAML.read_text(encoding="utf-8"))
    vcfg = svc["vllm"]
    prof = svc.get("serve")
    if not isinstance(prof, dict):
        print("ERROR: vllm-lmcache-nixl.yaml must define serve (mapping)", file=sys.stderr)
        return 1

    data_root = container_data_root()
    data_root.mkdir(parents=True, exist_ok=True)

    paths = svc.get("lmcache_paths")
    if prof.get("clear_gds_dir_before_start") and isinstance(paths, dict):
        sub = paths.get("subdir")
        if isinstance(sub, str) and sub.strip():
            disk = data_root / sub
            subprocess.run(["rm", "-fr", str(disk)], check=False)

    effective_lmcache = _materialize_lmcache_config(svc, data_root)
    if effective_lmcache is None:
        return 1

    rocr = os.environ.get("ROCR_VISIBLE_DEVICES", "0").strip() or "0"
    vllm_port = int(f"800{rocr}")
    lmcache_port = int(f"699{rocr}")

    env = os.environ.copy()
    env.pop("LMCACHE_EXTRA_CONFIG", None)
    _apply_pytorch_alloc_conf(env)
    env["PYTHONHASHSEED"] = "0"
    env["LMCACHE_CONFIG_FILE"] = str(effective_lmcache)
    env["LMCACHE_INTERNAL_API_SERVER_ENABLED"] = "true"
    env["LMCACHE_INTERNAL_API_SERVER_PORT_START"] = str(lmcache_port)
    env["MIOPEN_USER_DB_PATH"] = "/app/miopen"
    env["MIOPEN_FIND_MODE"] = "FAST"
    env["VLLM_ROCM_USE_AITER"] = "1"
    env["AMDGCN_USE_BUFFER_OPS"] = "0"
    if _truthy("VLLM_SERVER_DEV_MODE", "1"):
        env["VLLM_SERVER_DEV_MODE"] = "1"
    else:
        env.pop("VLLM_SERVER_DEV_MODE", None)
    _apply_chunk_statistics_env(env)
    _apply_kv_events_env(env)
    _apply_lmcache_log_level(env)
    _apply_nixl_runtime_env(env, svc)

    mode = _lmcache_io_mode()
    if _ais_hipfile_io_mode(mode):
        env["HIPFILE_UNSUPPORTED_FILE_SYSTEMS"] = "true"
        env["HIPFILE_ALLOW_COMPAT_MODE"] = "false"
        env["HIPFILE_STATS_LEVEL"] = "0"

    model = os.environ.get("VLLM_MODEL", "").strip() or str(vcfg["model_default"])
    gpu_mem = (
        os.environ.get("VLN_GPU_MEMORY_UTILIZATION", "").strip()
        or os.environ.get("VLLM_GPU_MEMORY_UTILIZATION", "").strip()
        or str(vcfg["gpu_memory_utilization_default"])
    )
    max_len = (
        os.environ.get("VLN_MAX_MODEL_LEN", "").strip()
        or str(vcfg["max_model_len_default"])
    )
    max_batched = (
        os.environ.get("VLN_MAX_NUM_BATCHED_TOKENS", "").strip()
        or str(vcfg["max_num_batched_tokens_default"])
    )

    kv_obj = svc.get("vllm_kv_transfer")
    if not isinstance(kv_obj, dict):
        print(
            "ERROR: vllm-lmcache-nixl.yaml must define vllm_kv_transfer as a mapping",
            file=sys.stderr,
        )
        return 1
    kv_raw = json.dumps(kv_obj, separators=(",", ":"))

    cmd: list[str] = ["vllm", "serve", model]
    cmd.extend(
        [
            "--host",
            str(vcfg["host"]),
            "--port",
            str(vllm_port),
            "--max-model-len",
            max_len,
            "--tensor-parallel-size",
            str(int(vcfg["tensor_parallel_size"])),
            "--gpu-memory-utilization",
            gpu_mem,
            "--block-size",
            str(int(vcfg["block_size"])),
            "--enable-prefix-caching",
            "--kv-cache-dtype=fp8",
            "--stream-interval",
            str(int(vcfg["stream_interval"])),
            "--max-num-batched-tokens",
            max_batched,
            "--async-scheduling",
            "--attention-backend",
            str(vcfg["attention_backend"]),
            "--kv-transfer-config",
            kv_raw,
        ]
    )
    lf = prof.get("load_format")
    if isinstance(lf, str) and lf:
        cmd.extend(["--load-format", lf])
    if _enforce_eager():
        cmd.append("--enforce-eager")
    if _enable_mfu_metrics(prof):
        cmd.append("--enable-mfu-metrics")
    if prof.get("disable_uvicorn_access_log", True):
        cmd.append("--disable-uvicorn-access-log")

    for k in ("VLLM_GPU_MEMORY_UTILIZATION", "VLLM_ENFORCE_EAGER"):
        env.pop(k, None)

    log_root = container_server_log_dir()
    log_root.mkdir(parents=True, exist_ok=True)
    log_path = log_root / "server.txt"
    log_f = log_path.open("ab", buffering=0)
    listen = str(vcfg["host"])
    _io = _lmcache_io_mode()
    print(
        f"vllm-lmcache-nixl VLN_LMCACHE_IO={_io} "
        f"LMCACHE_CONFIG_FILE={env['LMCACHE_CONFIG_FILE']} "
        f"NIXL_PLUGIN_DIR={env.get('NIXL_PLUGIN_DIR', '')} "
        f"http://{listen}:{vllm_port}/v1 log={log_path}",
        flush=True,
    )
    proc = subprocess.Popen(
        cmd,
        env=env,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    assert proc.stdout is not None
    tee = threading.Thread(
        target=_tee_thread,
        args=(proc.stdout, log_f),
        daemon=True,
    )
    tee.start()
    rc = proc.wait()
    tee.join(timeout=30)
    proc.stdout.close()
    log_f.close()
    return int(rc)


if __name__ == "__main__":
    raise SystemExit(main())
