+    def _fd_for_index(self, index: int) -> int:
+        return self.fds[self.size - 1 - index]
+
+    def ensure_slot_sized(self, index: int) -> None:
+        """Size a pool file before the first O_DIRECT transfer to that slot."""
+        if not self.use_direct_io or self.slot_size <= 0:
+            return
+        with self.lock:
+            if index in self._sized_slots:
+                return
+            fd = self._fd_for_index(index)
+            try:
+                if os.fstat(fd).st_size >= self.slot_size:
+                    self._sized_slots.add(index)
+                    return
+            except OSError:
+                pass
+            os.ftruncate(fd, self.slot_size)
+            self._sized_slots.add(index)
+
