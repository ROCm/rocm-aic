#!/usr/bin/env bash
# Mock curl for run-long CI: writes a minimal chat completion and HTTP 200.
set -euo pipefail

outfile=""
write_fmt=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o)
      outfile="$2"
      shift 2
      ;;
    -w)
      write_fmt="$2"
      shift 2
      ;;
    -d)
      shift
      if [[ "${1:-}" == "@-" ]]; then
        cat >/dev/null
        shift
      elif [[ -n "${1:-}" ]]; then
        shift
      fi
      ;;
    -H | -sS | -S | -s)
      shift 2
      ;;
    http://* | https://*)
      shift
      ;;
    *)
      shift
      ;;
  esac
done

if [[ -n "${write_fmt}" ]]; then
  printf '200 0.001'
fi

if [[ -n "${outfile}" ]]; then
  printf '%s\n' \
    '{"id":"ci","object":"chat.completion","choices":[{"index":0,"message":{"role":"assistant","content":"ok"},"finish_reason":"stop"}]}' \
    >"${outfile}"
fi

exit 0
