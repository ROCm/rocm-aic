#! /bin/bash
#
# Data layout: host ./vllm-container sets HF_HOME and KURT_CONTAINER_DATA_DIR.

[ -z "${ROCR_VISIBLE_DEVICES}" ] && { echo "Error: ROCR_VISIBLE_DEVICES not set" >&2; exit 1; }

KURT_CONTAINER_DATA_DIR="${KURT_CONTAINER_DATA_DIR:-${VLLM_CONTAINER_DATA_DIR:-/data}}"
CHUNK_DIR="${KURT_CONTAINER_DATA_DIR}/lmcache_chunk_stats"
mkdir -p "${CHUNK_DIR}"

PORT=${ROCR_VISIBLE_DEVICES}
LMCACHE_PORT="699${PORT}"
VLLM_PORT="800${PORT}"
VLLM_MODEL="${VLLM_MODEL:-meta-llama/Llama-3.1-8B-Instruct}"
# Not VLLM_* — vLLM logs unknown VLLM_FOO env vars. Legacy VLLM_GPU_MEMORY_* still read.
KURT_GPU_MEMORY_UTILIZATION="${KURT_GPU_MEMORY_UTILIZATION:-${VLLM_GPU_MEMORY_UTILIZATION:-0.72}}"
# Cap context so KV profiling fits ~16 GiB; MI300: export KURT_MAX_MODEL_LEN=131072
KURT_MAX_MODEL_LEN="${KURT_MAX_MODEL_LEN:-8192}"
KURT_MAX_NUM_BATCHED_TOKENS="${KURT_MAX_NUM_BATCHED_TOKENS:-4096}"
# Default --enforce-eager on. Opt out: export KURT_ENFORCE_EAGER=0 (or VLLM_ENFORCE_EAGER=0).
VLLM_ENFORCE_EAGER_FLAG=""
case "${KURT_ENFORCE_EAGER:-${VLLM_ENFORCE_EAGER:-1}}" in
  0|false|FALSE|no|NO|off|OFF) ;;
  *) VLLM_ENFORCE_EAGER_FLAG="--enforce-eager" ;;
esac
if [ -n "${KURT_PYTORCH_ALLOC_CONF:-}" ]; then
  export PYTORCH_ALLOC_CONF="${KURT_PYTORCH_ALLOC_CONF}"
elif [ -n "${VLLM_PYTORCH_ALLOC_CONF:-}" ]; then
  export PYTORCH_ALLOC_CONF="${VLLM_PYTORCH_ALLOC_CONF}"
fi
# Strip legacy names so the vllm child does not log unknown VLLM_* env vars.
unset VLLM_GPU_MEMORY_UTILIZATION VLLM_ENFORCE_EAGER 2>/dev/null || true

PYTHONHASHSEED=0 \
LMCACHE_ENABLE_CHUNK_STATISTICS=true \
LMCACHE_CHUNK_STATISTICS_AUTO_START_STATISTICS=true \
LMCACHE_CHUNK_STATISTICS_STRATEGY=file_hash \
LMCACHE_EXTRA_CONFIG="{\"chunk_statistics_file_output_dir\":\"${CHUNK_DIR}\",\"chunk_statistics_file_rotation_size\":104857600,\"chunk_statistics_file_max_count\":100}" \
LMCACHE_LOCAL_DISK="file://${KURT_CONTAINER_DATA_DIR}/lmcache_test/" \
LMCACHE_MAX_LOCAL_DISK_SIZE=1500.0 \
LMCACHE_INTERNAL_API_SERVER_ENABLED=true \
LMCACHE_INTERNAL_API_SERVER_PORT_START=${LMCACHE_PORT} \
LMCACHE_CHUNK_SIZE=256 \
LMCACHE_LOCAL_CPU=False \
LMCACHE_MAX_LOCAL_CPU_SIZE=48 \
MIOPEN_USER_DB_PATH=/app/miopen \
MIOPEN_FIND_MODE=FAST \
VLLM_ROCM_USE_AITER=1 \
AMDGCN_USE_BUFFER_OPS=0 \
vllm serve "${VLLM_MODEL}"   \
    --host localhost \
    --port "${VLLM_PORT}" \
    --max-model-len "${KURT_MAX_MODEL_LEN}" \
    --tensor-parallel-size 1 \
    --gpu-memory-utilization "${KURT_GPU_MEMORY_UTILIZATION}" \
    ${VLLM_ENFORCE_EAGER_FLAG} \
    --block-size 64 \
    --enable-prefix-caching \
    --stream-interval 20 \
    --max-num-batched-tokens "${KURT_MAX_NUM_BATCHED_TOKENS}" \
    --async-scheduling \
    --attention-backend ROCM_AITER_UNIFIED_ATTN \
    --kv-transfer-config \
    '{"kv_connector":"LMCacheConnectorV1", "kv_role":"kv_both"}' \
    | tee "${KURT_CONTAINER_DATA_DIR}/server.txt" &
