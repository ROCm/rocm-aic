#! /bin/bash
#
# Data layout: host ./vllm-container sets VLLM_CONTAINER_DATA_DIR (default /data).

VLLM_CONTAINER_DATA_DIR="${VLLM_CONTAINER_DATA_DIR:-/data}"
DATA="${VLLM_CONTAINER_DATA_DIR}/rand1G.dat"

if ! [ -e "$DATA" ]; then
    dd if=/dev/urandom of="$DATA" bs=1G count=1
fi

HIPFILE_UNSUPPORTED_FILE_SYSTEMS=true \
HIPFILE_ALLOW_COMPAT_MODE=false \
/app/fio/fio \
  --time_based \
  --ramp_time=5s \
  --runtime=10s \
  --filename="${DATA}" \
  --direct=1 \
  --rw=read \
  --bs=128M \
  --name=bw \
  --numjobs=1 \
  --ioengine=libhipfile \
  --rocm_io=hipfile \
  --gpu_dev_ids=0
