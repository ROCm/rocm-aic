GPU="${GPU:-0}"
# Host paths (sources for docker -v). In-container targets: see CONTAINER_* below.
DATA="${DATA:-/mnt/lmcache-nvme}"
HF_HOME="${HF_HOME:-${HOME}/.cache/huggingface}"
HF_TOKEN_FILE="${HF_TOKEN_FILE:-${HOME}/.batesste-hugging-face-read-march-2026.token}"

if [ -z "${HF_TOKEN}" ] && [ -r "${HF_TOKEN_FILE}" ]; then
  HF_TOKEN="$(tr -d '\r\n' < "${HF_TOKEN_FILE}")"
fi

if [ -z "${HF_TOKEN}" ]; then
  echo "Error: HF_TOKEN not set and not readable from HF_TOKEN_FILE=${HF_TOKEN_FILE}" >&2
  exit 1
fi

mkdir -p "${DATA}" "${HF_HOME}"
# Subdirs on the host so Hub / Transformers / vLLM never fall back to
# /root/.cache inside the writable image layer (duplicate downloads).
mkdir -p \
  "${HF_HOME}/hub" \
  "${HF_HOME}/datasets" \
  "${HF_HOME}/vllm" \
  "${HF_HOME}/vllm_config" \
  "${HF_HOME}/torch" \
  "${HF_HOME}/torch_inductor"

# In-container mount points: passed into docker run; host DATA/HF_HOME mount
# there. App scripts read KURT_CONTAINER_DATA_DIR (default /data); Hugging Face
# uses HF_HOME (default /hf). Override CONTAINER_* only if you change -v dests.
CONTAINER_HF_HOME="${CONTAINER_HF_HOME:-/hf}"
CONTAINER_DATA_DIR="${CONTAINER_DATA_DIR:-/data}"

docker run -it --rm \
  --name=gpu"${GPU}" \
  --hostname=gpu"${GPU}" \
  --ipc=host \
  --network=host \
  --cap-add=CAP_SYS_ADMIN \
  --cap-add=SYS_PTRACE \
  --security-opt seccomp=unconfined \
  --device=/dev/kfd \
  --device=/dev/dri \
  --env HF_HOME="${CONTAINER_HF_HOME}" \
  --env HUGGINGFACE_HUB_CACHE="${CONTAINER_HF_HOME}/hub" \
  --env HF_HUB_CACHE="${CONTAINER_HF_HOME}/hub" \
  --env HF_DATASETS_CACHE="${CONTAINER_HF_HOME}/datasets" \
  --env VLLM_CACHE_ROOT="${CONTAINER_HF_HOME}/vllm" \
  --env VLLM_CONFIG_ROOT="${CONTAINER_HF_HOME}/vllm_config" \
  --env TORCH_HOME="${CONTAINER_HF_HOME}/torch" \
  --env TORCHINDUCTOR_CACHE_DIR="${CONTAINER_HF_HOME}/torch_inductor" \
  --env KURT_CONTAINER_DATA_DIR="${CONTAINER_DATA_DIR}" \
  --env HF_TOKEN="${HF_TOKEN}" \
  --env ROCR_VISIBLE_DEVICES="${GPU}" \
  --env PYTORCH_ALLOC_CONF="${PYTORCH_ALLOC_CONF:-expandable_segments:True}" \
  -v "${HF_HOME}":"${CONTAINER_HF_HOME}" \
  -v "${DATA}":"${CONTAINER_DATA_DIR}" \
  -v /boot/config-"$(uname -r)":/boot/config-"$(uname -r)":ro \
  vllm-kurt
