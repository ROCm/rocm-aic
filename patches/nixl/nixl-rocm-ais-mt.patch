# ROCm/HIP + AIS_MT support for upstream ai-dynamo/nixl.
#
# Adds an AMD ROCm/HIP multi-threaded storage backend (AIS_MT, hipFile-backed)
# to upstream NIXL, plus HIP detection in meson that is independent of CUDA.
# Derived from sbates130272/nixl @ feat/amd-ais-mt (commits 70aa274 "plugins:
# add ROCM_AIS and AIS_MT" + 409e486 "build: detect HIP independently of CUDA"),
# reduced to the AIS_MT-only footprint: upstream's CUDA GDS_MT plugin is left
# untouched where upstream keeps it (src/plugins/gds_mt) rather than relocated
# under src/plugins/mt/gds. Decoupling from GDS_MT keeps this patch stable across
# upstream churn -- it applies cleanly on both NIXL v1.3.0 and v1.3.1.
#
# Scope: meson HIP detection + AIS_MT registration + the new
# src/plugins/mt/{ais,common} tree only. The GDS_MT relocation, and the
# CI/bench/docs/tests from the fork, are intentionally excluded.
#
# After this applies, meson.build has hip_dep and src/plugins/meson.build has
# enabled_plugins.get('AIS_MT'), so build-nixl.sh takes its _NATIVE_HIP branch
# (-Dwheel_variant=rocm -Drocm_ais_path=$AIS_PATH) and builds the AIS_MT plugin.
#
# To regenerate on a NIXL bump: clone the new tag, `git apply` this patch, and
# if it fails, re-derive it -- add the AIS_MT block + subdir('mt') beside the
# upstream GDS_MT block in src/plugins/meson.build (leave subdir('gds_mt')
# intact), keep src/plugins/mt/{ais,common} (no mt/gds), then
#   git diff --cached --no-renames -- meson.build meson_options.txt \
#     src/plugins/meson.build src/plugins/mt
#
diff --git a/meson.build b/meson.build
index 85fae88..02b3804 100644
--- a/meson.build
+++ b/meson.build
@@ -29,7 +29,7 @@ if enable_plugins_opt != '' and disable_plugins_opt != ''
     error('Cannot specify both enable_plugins and disable_plugins options')
 endif
 
-all_plugins = ['UCX', 'LIBFABRIC', 'POSIX', 'OBJ', 'GDS', 'GDS_MT', 'MOONCAKE', 'HF3FS', 'GUSLI', 'GPUNETIO', 'UCCL', 'AZURE_BLOB', 'INFINIA', 'TELEMETRY_DOCA']
+all_plugins = ['UCX', 'LIBFABRIC', 'POSIX', 'OBJ', 'GDS', 'GDS_MT', 'AIS_MT', 'MOONCAKE', 'HF3FS', 'GUSLI', 'GPUNETIO', 'UCCL', 'AZURE_BLOB', 'INFINIA', 'TELEMETRY_DOCA']
 
 enabled_plugins = {}
 
@@ -324,6 +324,33 @@ else
     cuda_wheel_dir = 'nixl_cu12'
 endif
 
+# --- ROCm / HIP detection (independent of CUDA; both stacks may coexist) ---
+hip_dep = disabler()
+rocm_home = run_command('bash', '-c', 'echo ${ROCM_PATH:-${ROCM_HOME:-/opt/rocm}}').stdout().strip()
+if rocm_home == ''
+    rocm_home = '/opt/rocm'
+endif
+hip_lib = rocm_home + '/lib'
+hip_inc = rocm_home + '/include'
+if fs.exists(hip_lib) and fs.exists(hip_inc)
+    hip_dep = declare_dependency(
+        link_args : ['-L' + hip_lib, '-lamdhip64'],
+        include_directories : include_directories(hip_inc))
+    message('Found ROCm/HIP installation: ' + rocm_home)
+endif
+
+if hip_dep.found()
+    add_project_arguments('-DHAVE_HIP', language: 'cpp')
+    add_project_arguments('-D__HIP_PLATFORM_AMD__', language: 'cpp')
+    message('ROCm/HIP support enabled')
+endif
+
+if cuda_dep.found() and hip_dep.found()
+    message('CUDA and ROCm/HIP are both available; NVIDIA and AMD plugin stacks may be built together when enabled.')
+endif
+
+has_gpu = cuda_dep.found() or hip_dep.found()
+
