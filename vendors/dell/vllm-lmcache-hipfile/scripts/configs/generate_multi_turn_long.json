{
    "filetype": "generate_conversations",
    "num_conversations": 240,
    "text_files": ["configs/books.txt"],
    "print_stats": false,
    "prompt_input": {
        "num_turns": {
            "distribution": "uniform",
            "min": 24,
            "max": 36
        },
        "common_prefix_num_tokens": {
            "distribution": "constant",
            "value": 15000
        },
        "prefix_num_tokens": {
            "distribution": "lognormal",
            "average": 6000,
            "max": 10000
        },
        "num_tokens": {
            "distribution": "uniform",
            "min": 500,
            "max": 1000
        }
    },
    "prompt_output": {
        "num_tokens": {
            "distribution": "uniform",
            "min": 2000,
            "max": 4000
        }
    }
}
