---
# Example Weka cluster inventory.
#
# Three logical groups:
#   weka_servers – contribute NVMe storage
#   weka_clients – mount the Weka FS only
#   weka_both    – server + client on same node
#
# Place real hostnames (or IPs) under each group
# and set per-host overrides as host_vars.
#
# Drive modes:
#   1. Auto-detect NVMe: leave nvme_drives empty
#   2. Explicit NVMe: list specific device paths

all:
  children:

    weka_servers:
      hosts:
        weak-server:
          weka_cluster_nic: "eth0"
          weka_cluster_nvme_drives:
            - /dev/nvme0n1
            - /dev/nvme1n1
            - /dev/nvme2n1
            - /dev/nvme3n1
            - /dev/nvme4n1
            - /dev/nvme5n1
        server2.example.com:
          weka_cluster_nic: "eth0"
          weka_cluster_nvme_drives:
            - /dev/nvme0n1
            - /dev/nvme1n1
            - /dev/nvme2n1
            - /dev/nvme3n1
            - /dev/nvme4n1
            - /dev/nvme5n1

    weka_clients:
      hosts:
        client1.example.com: {}

    weka_both:
      hosts:
        combo1.example.com:
          weka_cluster_nic: "rdma0"
          weka_cluster_num_containers: 3
          weka_cluster_nvme_drives:
            - /dev/nvme0n1
            - /dev/nvme1n1
