# Prerequisites setup for LLM-D deployment
# This justfile helps install and configure all required tools and cluster components

# Import common LLM-D helpers
import? "../common/llm-d-helpers.justfile"

# Root path to ROCM_ICMS repository
ROCM_ICMS := justfile_directory() / ".." / ".." / ".."

# Minikube binary path
MINIKUBE_BIN := "/usr/local/bin/minikube"

# ============================================================================
# Minikube Installation & Setup
# ============================================================================

# Download and install minikube to /usr/local/bin
minikube-install:
    #!/usr/bin/env bash
    set -euo pipefail

    echo -e "{{GREEN}}Installing minikube...{{NC}}"

    if command -v minikube &> /dev/null; then
        echo -e "{{YELLOW}}minikube already installed: $(minikube version --short){{NC}}"
        exit 0
    fi

    # Download latest minikube for Linux AMD64
    echo "Downloading minikube..."
    if ! curl -Lo /tmp/minikube https://storage.googleapis.com/minikube/releases/latest/minikube-linux-amd64; then
        echo -e "{{RED}}Error: Failed to download minikube{{NC}}" >&2
        echo -e "{{YELLOW}}Completed: none{{NC}}"
        echo -e "{{YELLOW}}Remaining: minikube-install{{NC}}"
        exit 1
    fi

    # Install minikube
    echo "Installing to {{MINIKUBE_BIN}}..."
    if ! sudo install /tmp/minikube {{MINIKUBE_BIN}}; then
        rm -f /tmp/minikube
        echo -e "{{RED}}Error: Failed to install minikube to {{MINIKUBE_BIN}}{{NC}}" >&2
        echo -e "{{YELLOW}}Completed: download{{NC}}"
        echo -e "{{YELLOW}}Remaining: installation to {{MINIKUBE_BIN}}{{NC}}"
        exit 1
    fi

    # Cleanup
    rm -f /tmp/minikube

    echo -e "{{GREEN}}✅ minikube installed successfully: $({{MINIKUBE_BIN}} version --short){{NC}}"

# Start minikube with Docker driver and AMD GPU support
minikube-start:
    #!/usr/bin/env bash
    set -euo pipefail

    if ! command -v minikube &> /dev/null; then
        echo -e "{{RED}}Error: minikube not found. Run 'just -f {{source_file()}} minikube-install' first{{NC}}" >&2
        exit 1
    fi

    # Check if minikube is already running
    if {{MINIKUBE_BIN}} status &> /dev/null; then
        echo -e "{{RED}}Error: minikube is already running{{NC}}" >&2
        echo ""
        echo "Current status:"
        {{MINIKUBE_BIN}} status
        echo ""
        echo "To restart minikube, first run 'just -f {{source_file()}} minikube-stop'"
        exit 1
    fi

    echo -e "{{GREEN}}Starting minikube with AMD GPU support...{{NC}}"
    # Local folder can be mounted in the minikube container using
    # `--mount --mount-string="/host/path:/container/path"`
    if ! {{MINIKUBE_BIN}} start --driver=docker --container-runtime=docker --gpus amd; then
        echo -e "{{RED}}Error: Failed to start minikube{{NC}}" >&2
        exit 1
    fi

    echo -e "{{GREEN}}✅ minikube started successfully{{NC}}"
    {{MINIKUBE_BIN}} status

# Stop minikube
minikube-stop:
    #!/usr/bin/env bash
    set -euo pipefail

    if ! command -v minikube &> /dev/null; then
        echo -e "{{RED}}Error: minikube not found{{NC}}" >&2
        exit 1
    fi

    echo -e "{{YELLOW}}Stopping minikube...{{NC}}"
    if ! {{MINIKUBE_BIN}} stop; then
        echo -e "{{RED}}Error: Failed to stop minikube{{NC}}" >&2
        exit 1
    fi

    echo -e "{{GREEN}}✅ minikube stopped{{NC}}"

# Install AMD GPU device plugin daemon set in the cluster
minikube-setup:
    #!/usr/bin/env bash
    set -euo pipefail

    # Check if minikube is installed, install if not
    if ! command -v minikube &> /dev/null; then
        echo -e "{{YELLOW}}minikube not found, installing...{{NC}}"
        just minikube-install
    fi

    echo -e "{{GREEN}}Installing AMD GPU device plugin...{{NC}}"

    # Verify kubectl can connect
    if ! kubectl cluster-info &> /dev/null; then
        echo -e "{{RED}}Error: Cannot connect to Kubernetes cluster{{NC}}" >&2
        echo -e "{{YELLOW}}Is minikube running? Try 'just -f {{source_file()}}  minikube-start'{{NC}}"
        exit 1
    fi

    # Install AMD GPU device plugin
    if ! kubectl create -f https://raw.githubusercontent.com/ROCm/k8s-device-plugin/master/k8s-ds-amdgpu-dp.yaml; then
        # Check if it already exists
        if kubectl get daemonset amd-gpu-device-plugin -n kube-system &> /dev/null; then
            echo -e "{{YELLOW}}AMD GPU device plugin already installed{{NC}}"
        else
            echo -e "{{RED}}Error: Failed to install AMD GPU device plugin{{NC}}" >&2
            echo -e "{{YELLOW}}Completed: none{{NC}}"
            echo -e "{{YELLOW}}Remaining: AMD GPU device plugin installation{{NC}}"
            exit 1
        fi
    fi

    echo -e "{{GREEN}}✅ AMD GPU device plugin installed{{NC}}"
    echo "Waiting for daemon set to be ready..."
    kubectl rollout status daemonset/amd-gpu-device-plugin -n kube-system --timeout=60s || true

# ============================================================================
# LLM-D Cluster Setup
# ============================================================================
# Note: register-hf-token is now available from ../common/llm-d-helpers.justfile

# Install Prometheus and Grafana monitoring stack
install-monitoring:
    #!/usr/bin/env bash
    set -euo pipefail

    echo -e "{{GREEN}}Installing Prometheus and Grafana...{{NC}}"

    MONITORING_DIR="{{ROCM_ICMS}}/submodules/llm-d/docs/monitoring"

    # Verify monitoring directory exists
    if [ ! -d "$MONITORING_DIR" ]; then
        echo -e "{{RED}}Error: Monitoring directory not found: $MONITORING_DIR{{NC}}" >&2
        echo -e "{{YELLOW}}Is the llm-d submodule initialized?{{NC}}"
        exit 1
    fi

    # Verify install script exists
    if [ ! -f "$MONITORING_DIR/scripts/install-prometheus-grafana.sh" ]; then
        echo -e "{{RED}}Error: Install script not found{{NC}}" >&2
        echo -e "{{YELLOW}}Path: $MONITORING_DIR/scripts/install-prometheus-grafana.sh{{NC}}"
        exit 1
    fi

    # Run installation script
    cd "$MONITORING_DIR"
    if ! ./scripts/install-prometheus-grafana.sh --enable-tls; then
        echo -e "{{RED}}Error: Failed to install monitoring stack{{NC}}" >&2
        echo -e "{{YELLOW}}Completed: validation{{NC}}"
        echo -e "{{YELLOW}}Remaining: Prometheus/Grafana installation{{NC}}"
        exit 1
    fi

    echo -e "{{GREEN}}✅ Monitoring stack installed{{NC}}"

# Install gateway provider (includes Istio installation)
install-gateway-provider:
    #!/usr/bin/env bash
    set -euo pipefail

    echo -e "{{GREEN}}Installing gateway provider (includes Istio)...{{NC}}"

    GATEWAY_DIR="{{ROCM_ICMS}}/submodules/llm-d/guides/prereq/gateway-provider"

    # Verify gateway provider directory exists
    if [ ! -d "$GATEWAY_DIR" ]; then
        echo -e "{{RED}}Error: Gateway provider directory not found: $GATEWAY_DIR{{NC}}" >&2
        echo -e "{{YELLOW}}Is the llm-d submodule initialized?{{NC}}"
        exit 1
    fi

    # Verify install script exists
    if [ ! -f "$GATEWAY_DIR/install-gateway-provider-dependencies.sh" ]; then
        echo -e "{{RED}}Error: Gateway provider install script not found{{NC}}" >&2
        exit 1
    fi

    # Verify helmfile exists
    if [ ! -f "$GATEWAY_DIR/istio.helmfile.yaml" ]; then
        echo -e "{{RED}}Error: istio.helmfile.yaml not found{{NC}}" >&2
        exit 1
    fi

    # Install Gateway API CRDs
    cd "$GATEWAY_DIR"
    echo "Installing Gateway API CRDs..."
    if ! ./install-gateway-provider-dependencies.sh; then
        echo -e "{{RED}}Error: Failed to install Gateway API CRDs{{NC}}" >&2
        echo -e "{{YELLOW}}Completed: validation{{NC}}"
        echo -e "{{YELLOW}}Remaining: Gateway API CRDs installation, Istio installation{{NC}}"
        exit 1
    fi

    # Apply helmfile (installs istio-base and istiod)
    echo "Installing Istio (istio-base and istiod)..."
    if ! helmfile apply -f istio.helmfile.yaml; then
        echo -e "{{RED}}Error: Failed to install Istio via helmfile{{NC}}" >&2
        echo -e "{{YELLOW}}Completed: Gateway API CRDs{{NC}}"
        echo -e "{{YELLOW}}Remaining: Istio installation (istio-base, istiod){{NC}}"
        exit 1
    fi

    echo -e "{{GREEN}}✅ Gateway provider installed (Istio included){{NC}}"

# Complete LLM-D cluster setup (runs all setup steps)
llm-d-setup: install-monitoring install-gateway-provider
    @echo "{{GREEN}}✅ LLM-D cluster setup complete!{{NC}}"
    @echo ""
    @echo "Setup completed:"
    @echo "  ✅ Monitoring stack (Prometheus/Grafana) installed"
    @echo "  ✅ Gateway provider installed (includes Istio service mesh)"
    @echo ""

# ============================================================================
# Verification & Status
# ============================================================================

# Verify tool prerequisites (just, helm, helmfile, kubectl, minikube)
verify-tools-prereqs:
    #!/usr/bin/env bash
    set -euo pipefail

    echo -e "{{GREEN}}Checking tool prerequisites...{{NC}}"
    echo ""

    MISSING=0

    # Check just
    if command -v just &> /dev/null; then
        echo -e "{{GREEN}}✅ just: $(just --version){{NC}}"
    else
        echo -e "{{RED}}❌ just not found{{NC}}"
        MISSING=1
    fi

    # Check helm
    if command -v helm &> /dev/null; then
        echo -e "{{GREEN}}✅ helm: $(helm version --short){{NC}}"
    else
        echo -e "{{RED}}❌ helm not found{{NC}}"
        MISSING=1
    fi

    # Check helmfile
    if command -v helmfile &> /dev/null; then
        echo -e "{{GREEN}}✅ helmfile: $(helmfile --version){{NC}}"
    else
        echo -e "{{RED}}❌ helmfile not found{{NC}}"
        MISSING=1
    fi

    # Check kubectl
    if command -v kubectl &> /dev/null; then
        echo -e "{{GREEN}}✅ kubectl: $(kubectl version --client --short 2>/dev/null || kubectl version --client){{NC}}"
    else
        echo -e "{{RED}}❌ kubectl not found{{NC}}"
        MISSING=1
    fi

    # Check minikube
    if command -v minikube &> /dev/null; then
        echo -e "{{GREEN}}✅ minikube: $(minikube version --short){{NC}}"
    else
        echo -e "{{YELLOW}}⚠️  minikube not found (run 'just -f {{source_file()}} minikube-install'){{NC}}"
    fi

    echo ""

    if [ $MISSING -eq 1 ]; then
        echo -e "{{YELLOW}}Some tool prerequisites are missing. Run './prereqs.sh -y' to install them.{{NC}}"
        exit 1
    else
        echo -e "{{GREEN}}All tool prerequisites verified!{{NC}}"
    fi

# Verify LLM-D cluster prerequisites (AMD GPU plugin, HF token, monitoring, gateway)
verify-llm-d-prereqs:
    #!/usr/bin/env bash
    set -euo pipefail

    echo -e "{{GREEN}}Checking LLM-D cluster prerequisites...{{NC}}"
    echo ""

    MISSING=0

    # Verify kubectl can connect to cluster
    if ! kubectl cluster-info &> /dev/null; then
        echo -e "{{RED}}❌ Cannot connect to Kubernetes cluster{{NC}}"
        echo -e "{{YELLOW}}   Is minikube running? Try 'just -f {{source_file()}} minikube-start'{{NC}}"
        exit 1
    fi

    # Check AMD GPU device plugin
    if kubectl get daemonset amd-gpu-device-plugin -n kube-system &> /dev/null || \
       kubectl get daemonset default-device-plugin -n kube-amd-gpu &> /dev/null; then
        echo -e "{{GREEN}}✅ AMD GPU device plugin installed{{NC}}"
    else
        echo -e "{{RED}}❌ AMD GPU device plugin not found{{NC}}"
        echo -e "{{YELLOW}}   Run 'just -f {{source_file()}} minikube-setup' to install{{NC}}"
        MISSING=1
    fi

    # Check Prometheus installation
    if kubectl get namespace llm-d-monitoring &> /dev/null; then
        echo -e "{{GREEN}}✅ Monitoring namespace exists{{NC}}"
    else
        echo -e "{{RED}}❌ Monitoring stack not installed{{NC}}"
        echo -e "{{YELLOW}}   Run 'just -f {{source_file()}} install-monitoring' to install{{NC}}"
        MISSING=1
    fi

    # Check Istio and gateway provider installation
    if kubectl get namespace istio-system &> /dev/null; then
        # Check if both istio-base and istiod are installed
        if helm list -n istio-system 2>/dev/null | grep -q "istio-base" && \
           helm list -n istio-system 2>/dev/null | grep -q "istiod"; then
            echo -e "{{GREEN}}✅ Gateway provider installed (Istio included){{NC}}"
        else
            echo -e "{{RED}}❌ Gateway provider partially installed{{NC}}"
            echo -e "{{YELLOW}}   Run 'just -f {{source_file()}} install-gateway-provider' to complete installation{{NC}}"
            MISSING=1
        fi
    else
        echo -e "{{RED}}❌ Gateway provider not installed (Istio missing){{NC}}"
        echo -e "{{YELLOW}}   Run 'just -f {{source_file()}} install-gateway-provider' to install{{NC}}"
        MISSING=1
    fi

    echo ""

    if [ $MISSING -eq 1 ]; then
        echo -e "{{YELLOW}}Some LLM-D prerequisites are missing. Run 'just -f {{source_file()}} llm-d-setup' to install them.{{NC}}"
        exit 1
    else
        echo -e "{{GREEN}}All LLM-D cluster prerequisites verified!{{NC}}"
    fi

# Verify all prerequisites (tools and LLM-D cluster components)
verify-prereqs: verify-tools-prereqs verify-llm-d-prereqs
    @echo ""
    @echo "{{GREEN}}✅ All prerequisites verified successfully!{{NC}}"

# Show cluster status
cluster-status:
    #!/usr/bin/env bash
    set -euo pipefail

    echo -e "{{GREEN}}Cluster Status:{{NC}}"
    echo ""

    # Minikube status
    if command -v minikube &> /dev/null; then
        echo "Minikube:"
        {{MINIKUBE_BIN}} status || echo "  Not running"
        echo ""
    fi

    # Kubectl cluster info
    if kubectl cluster-info &> /dev/null; then
        echo "Cluster Info:"
        kubectl cluster-info
        echo ""

        echo "Nodes:"
        kubectl get nodes
        echo ""

        echo "Namespaces:"
        kubectl get namespaces
    else
        echo -e "{{YELLOW}}Cannot connect to cluster{{NC}}"
    fi
