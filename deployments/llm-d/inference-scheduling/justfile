# Justfile for inference-scheduling deployment with AMD GPUs

# Default recipe - show available commands
default:
    @just --list

# Import common utilities
import? "../setup/justfile"
import? "../common/monitoring.justfile"
import? "../common/llm-d-helpers.justfile"

# Deployment-specific configuration
NAMESPACE := env_var_or_default('NAMESPACE', 'llm-d-inference-scheduling-amd')
MANIFEST_DIR := env_var_or_default('MANIFEST_DIR', './manifests/vllm')

# Complete setup: prereqs + namespace + deploy + wait
setup: verify-prereqs create-namespace deploy wait
    @echo "✅ Setup complete!"
    @echo "Run 'just status' to check deployment status"
    @echo "Run 'just port-forward-start' to access services"

# Deploy only
deploy: deploy-gateway deploy-model-server deploy-inferencepool
    @echo "✅ Deployment created!"

# Create namespace if it doesn't exist, and ensure HF token secret is configured
create-namespace:
    #!/usr/bin/env bash
    set -euo pipefail

    # Check if namespace exists
    if kubectl get namespace {{NAMESPACE}} &>/dev/null; then
        echo "⚠️  Warning: Namespace {{NAMESPACE}} already exists, continuing..."
    else
        echo "📦 Creating namespace {{NAMESPACE}}..."
        kubectl create namespace {{NAMESPACE}}
        echo "✅ Namespace {{NAMESPACE}} created"
    fi

    # Check if HF token secret exists
    if kubectl get secret {{HF_TOKEN_NAME}} -n {{NAMESPACE}} &>/dev/null; then
        echo "✅ HuggingFace token secret '{{HF_TOKEN_NAME}}' already exists in namespace {{NAMESPACE}}"
    else
        echo "⚠️  HuggingFace token secret '{{HF_TOKEN_NAME}}' not found in namespace {{NAMESPACE}}"
        echo "📝 Setting up HuggingFace token using llm-d-helpers..."
        just register-hf-token {{NAMESPACE}} || { echo "❌ Failed to register HF token. You may need to set HF_TOKEN environment variable and run: just register-hf-token {{NAMESPACE}}"; exit 1;}
    fi

# Delete namespace (WARNING: deletes everything!)
delete-namespace:
    @just _delete-namespace {{NAMESPACE}}

# Deploy Istio gateway (from llm-d submodule)
deploy-gateway:
    @echo "🚀 Deploying Istio gateway..."
    kubectl apply -k {{LLM_D_PATH}}/guides/recipes/gateway/istio -n {{NAMESPACE}} || exit 1
    @echo "✅ Gateway deployed"

# Deploy vLLM model servers using optimized-baseline structure
deploy-model-server:
    @echo "🚀 Deploying AMD vLLM model servers"
    kustomize build {{MANIFEST_DIR}} | kubectl apply -n {{NAMESPACE}} -f - || exit 1
    @echo "✅ Model servers deployed"

# Deploy InferencePool for intelligent routing
deploy-inferencepool:
    @echo "🚀 Deploying InferencePool..."
    helm install llm-d-infpool \
      {{INFERENCEPOOL_CHART}} \
      -f {{LLM_D_PATH}}/guides/recipes/scheduler/base.values.yaml \
      -f {{LLM_D_PATH}}/guides/recipes/scheduler/features/monitoring.values.yaml \
      -f {{LLM_D_PATH}}/guides/optimized-baseline/scheduler/optimized-baseline.values.yaml \
      --set provider.name=istio \
      --set experimentalHttpRoute.enabled=true \
      --set experimentalHttpRoute.inferenceGatewayName=llm-d-inference-gateway \
      -n {{NAMESPACE}} \
      --version {{INFERENCEPOOL_VERSION}} || exit 1
    @echo "✅ InferencePool deployed"

# Teardown everything
teardown: teardown-inferencepool teardown-model-server teardown-gateway
    @echo "✅ Full teardown complete!"

# Teardown InferencePool
teardown-inferencepool:
    @echo "🗑️  Removing InferencePool..."
    -helm uninstall llm-d-infpool -n {{NAMESPACE}}
    @echo "✅ InferencePool removed"

# Teardown model servers
teardown-model-server:
    @echo "🗑️  Removing model servers..."
    -kubectl delete -k {{MANIFEST_DIR}} -n {{NAMESPACE}}
    @echo "✅ Model servers removed"

# Teardown gateway
teardown-gateway:
    @echo "🗑️  Removing gateway..."
    -kubectl delete -k {{LLM_D_PATH}}/guides/recipes/gateway/istio -n {{NAMESPACE}}
    @echo "✅ Gateway removed"

# Check deployment status
status:
    @echo "📊 Deployment Status in namespace: {{NAMESPACE}}"
    @echo ""
    @echo "=== Helm Releases ==="
    -helm list -n {{NAMESPACE}}
    @echo ""
    @echo "=== Deployments ==="
    kubectl -n {{NAMESPACE}} get deployments
    @echo ""
    @echo "=== Pods ==="
    kubectl -n {{NAMESPACE}} get pods -o wide
    @echo ""
    @echo "=== Services ==="
    kubectl -n {{NAMESPACE}} get svc

# Wait for deployment to be ready
wait:
    @echo "⏳ Waiting for pods to be ready..."
    kubectl wait --for=condition=ready pod -l llm-d.ai/role=decode -n {{NAMESPACE}} --timeout=600s || true
    @echo "✅ Pods are ready!"

# View logs from model server pods
logs:
    @echo "📜 Model server logs:"
    @just _get-logs-by-label {{NAMESPACE}} "llm-d.ai/role=decode" 50

# Follow logs from model server pods
logs-follow:
    @echo "📜 Following model server logs (Ctrl+C to stop)..."
    @just _follow-logs-by-label {{NAMESPACE}} "llm-d.ai/role=decode"

# Test the deployment with a simple curl
test:
    @echo "🧪 Testing deployment..."
    @echo "Make sure port-forward is active (just port-forward-start)"
    curl -s localhost:8080/v1/models | jq .

# Start all port-forwards in background
port-forward-start:
    @echo "🔌 Starting port-forwards..."
    @just _port-forward-gateway-is
    @just _port-forward-prometheus
    @just _port-forward-grafana
    @echo "✅ Port-forwards started:"
    @echo "  🌐 Istio Gateway: http://localhost:8080"
    @echo "  📊 Prometheus: http://localhost:9090"
    @echo "  📈 Grafana: http://localhost:3000"
    @echo "Run 'just port-forward-stop' to stop them"

# Internal: Start Istio Gateway port-forward
_port-forward-gateway-is:
    #!/usr/bin/env bash
    set -euo pipefail
    # Kill existing port-forward if running
    pkill -f "port-forward.*gateway-istio.*8080" 2>/dev/null || true
    sleep 1
    # Start new port-forward
    kubectl port-forward -n {{NAMESPACE}} svc/llm-d-inference-gateway-istio 8080:80 > /dev/null 2>&1 &
    echo "  ✅ Istio Gateway port-forward started (PID: $!)"

# Stop all port-forwards
port-forward-stop:
    @echo "🔌 Stopping port-forwards..."
    -pkill -f "port-forward.*gateway-istio.*8080"
    @just stop-monitoring-port-forwards

# Complete cleanup: teardown and stop port-forwards
clean: teardown port-forward-stop
    @echo "🧹 Cleanup complete!"
    @echo "Run 'just delete-namespace' if you want to delete the namespace entirely"

squeaky-clean: teardown port-forward-stop delete-namespace
    @echo "🧹 Cleanup complete!"

# Test metrics endpoint from a model server pod
test-metrics:
    #!/usr/bin/env bash
    set -euo pipefail
    POD_NAME=$(kubectl get pods -n {{NAMESPACE}} -l llm-d.ai/role=decode -o jsonpath='{.items[0].metadata.name}')
    if [ -n "$POD_NAME" ]; then
        echo "📊 Testing metrics from pod: $POD_NAME"
        kubectl exec -n {{NAMESPACE}} ${POD_NAME} -c vllm -- curl -s http://localhost:8000/metrics | head -20
    else
        echo "❌ No vLLM pods found"
        exit 1
    fi

# Parse and show vLLM configuration from logs (deduplicated across pods)
show-config:
    @echo "Parsing vLLM configuration from pod logs..."
    @just _parse-vllm-all {{NAMESPACE}} "llm-d.ai/role=decode" "true"

# Show vLLM configuration for all pods separately (no deduplication)
show-config-all:
    @echo "Parsing vLLM configuration from all pods (no deduplication)..."
    @just _parse-vllm-all {{NAMESPACE}} "llm-d.ai/role=decode" "false"

# Show vLLM configuration for a specific pod
show-config-pod POD_NAME:
    @echo "Parsing vLLM configuration from pod {{POD_NAME}}..."
    @just _parse-vllm-pod {{NAMESPACE}} {{POD_NAME}}

# Load Grafana dashboards (llm-d defaults + rocm-icms custom)
load-dashboards:
    @echo "📊 Loading Grafana dashboards..."
    @just _load-dashboards
    @echo "✅ Dashboards loaded. Access Grafana at http://localhost:3000"
