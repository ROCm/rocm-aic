apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization


# Note: paths are relative to the result folder where the final yaml is assembled
# typically `results/sweeps/<sweep_name>/run-<run_id>/manifests`

# Use the Offloading flavor from tiered-prefix-cache
resources:
  - ../../../../../../tiered-prefix-cache/manifests/vllm/flavors/offloading

components:
  - ../../../../../../tiered-prefix-cache/manifests/vllm/components/hostpath-models

patches:
  - target:
      kind: Deployment
      name: decode
    patch: |-
      - op: replace
        path: /spec/replicas
        value: {{replicas}}
      - op: replace
        path: /spec/template/spec/containers/0/image
        value: {{image}}
      - op: replace
        path: /spec/template/spec/containers/0/args
        value:
          - "{{model}}"
          - "--port=8000"
          - "--disable-access-log-for-endpoints=/health,/metrics,/v1/models"
          - "--tensor-parallel-size={{tensor_parallel_size}}"
          {{ENGINE_ARGS_ARRAY}}
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/amd.com~1gpu
        value: "{{tensor_parallel_size}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/amd.com~1gpu
        value: "{{tensor_parallel_size}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/cpu
        value: "{{cpu}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/cpu
        value: "{{cpu}}"
      - op: replace
        path: /spec/template/spec/containers/0/resources/limits/memory
        value: {{memory}}
      - op: replace
        path: /spec/template/spec/containers/0/resources/requests/memory
        value: {{memory}}
