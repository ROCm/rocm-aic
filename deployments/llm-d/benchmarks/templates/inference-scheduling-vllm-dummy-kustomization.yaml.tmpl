apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

# Use the modern optimized-baseline modelserver structure
# This guide provides intelligent request routing with multiple vLLM replicas
resources:
  - ../../../../../../../../submodules/llm-d/guides/optimized-baseline/modelserver/amd/vllm

# Examples of customizations
patches:
  - target:
      kind: Deployment
      name: decode
    patch: |-
      - op: replace
        path: /spec/replicas
        value: 1
      - op: replace
        path: /spec/template/spec/containers/0/image
        value: ghcr.io/vcave/vllm:rocm_721-vllm_20260423b-lmcache
      - op: replace
        path: /spec/template/spec/containers/0/args
        value:
          - "{{model}}"
          - "--port=8000"
          - "--disable-access-log-for-endpoints=/health,/metrics,/v1/models"
          - "--tensor-parallel-size={{tensor_parallel_size}}"
          - "--gpu-memory-utilization=0.95"
          {{ENGINE_ARGS_ARRAY}}
      # This is meant for vllm with dummy model loading
      - op: add
        path: /spec/template/spec/containers/0/env/-
        value:
          name: HF_HOME
          value: "/root/hf"

  # Update resource requests (no large CPU cache needed)
  # NOTE: GPU count and other resources can be customized here
  - target:
      kind: Deployment
      name: decode
    patch: |-
      - op: replace
        path: /spec/template/spec/containers/0/resources
        value:
          limits:
            amd.com/gpu: {{tensor_parallel_size}}
            cpu: "32"
            memory: 100Gi
          requests:
            amd.com/gpu: {{tensor_parallel_size}}
            cpu: "32"
            memory: 100Gi
