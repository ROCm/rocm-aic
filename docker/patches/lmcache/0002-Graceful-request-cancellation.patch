From e0fdde344d5084796639edf93f04dd6d8f64e400 Mon Sep 17 00:00:00 2001
From: Vincent Cave <vincent.cave@amd.com>
Date: Thu, 21 May 2026 22:51:03 -0700
Subject: [PATCH] Graceful request cancellation

Signed-off-by: Vincent Cave <vincent.cave@amd.com>
---
 lmcache/integration/vllm/vllm_v1_adapter.py | 9 +++++----
 1 file changed, 5 insertions(+), 4 deletions(-)

diff --git a/lmcache/integration/vllm/vllm_v1_adapter.py b/lmcache/integration/vllm/vllm_v1_adapter.py
index 4fbb6a65..1074808d 100644
--- a/lmcache/integration/vllm/vllm_v1_adapter.py
+++ b/lmcache/integration/vllm/vllm_v1_adapter.py
@@ -1776,10 +1776,11 @@ class LMCacheConnectorV1Impl:
         # Cleanup if request was aborted
         if request.status == RequestStatus.FINISHED_ABORTED:
             # Notify storage backends of aborted requests
-            assert self.lmcache_engine is not None
-            sm = self.lmcache_engine.storage_manager
-            if sm is not None:
-                sm.cancel_request(request.request_id)
+            # assert self.lmcache_engine is not None
+            if self.lmcache_engine is not None:
+                sm = self.lmcache_engine.storage_manager
+                if sm is not None:
+                    sm.cancel_request(request.request_id)
 
             if self.async_loading:
                 # Cancel any ongoing async lookup and prefetch tasks on workers
-- 
