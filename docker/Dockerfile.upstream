ARG BASE_IMAGE=vllm/vllm-openai-rocm:v0.22.1
ARG PYTORCH_ROCM_ARCH="gfx942;gfx950"

ARG RIXL_SHA="39be1de"
ARG RIXL_REPO="https://github.com/ROCm/RIXL.git"
ARG UCX_SHA="da3fac2a"
ARG UCX_REPO="https://github.com/ROCm/ucx.git"
ARG ETCD_SHA="7c6e714"
ARG ETCD_REPO="https://github.com/etcd-cpp-apiv3/etcd-cpp-apiv3.git"

ARG HIPFILE_REPO="https://github.com/ROCm/rocm-systems.git"
ARG HIPFILE_SHA=adc1a2d2f8e886e93c5e55e674dbff6e05db2dbe

ARG LMCACHE_REPO="https://github.com/LMCache/LMCache.git"
ARG LMCACHE_SHA="7b0314fc614176cccf75a0b3d7b15165933d6698"


###
### Base image (uv, rdma, etc..)
###

FROM ${BASE_IMAGE} AS base

ARG CACHE_BUSTER
RUN if [ -n "${CACHE_BUSTER}" ]; then \
        echo "$CACHE_BUSTER" > /tmp/builder-buster; \
    fi;

ENV ROCM_PATH=/opt/rocm
ENV PATH=${ROCM_PATH}/llvm/bin:${ROCM_PATH}/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV LD_LIBRARY_PATH=${ROCM_PATH}/lib:/usr/local/lib:

ENV UCX_PATH=/usr/local/ucx
ENV RIXL_PATH=/usr/local/rixl
ENV RIXL_BENCH_PATH=/usr/local/rixl_bench

# RDMA libraries, hipfile dependences for build and runtime images
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get -y update && apt-get install -y \
    ccache \
    libibverbs-dev \
    ibverbs-providers \
    ibverbs-utils \
    libmount-dev \
    && rm -rf /var/lib/apt/lists/*

ENV CCACHE_DIR=/root/.cache/ccache


###
### RIXL + dependences build (until upstream rocm/vllm provides it in nightly or wheels become available)
###

FROM base AS build_rixl

ARG UCX_SHA
ARG UCX_REPO
ARG RIXL_SHA
ARG RIXL_REPO
ARG ETCD_SHA
ARG ETCD_REPO

# ligflags-dev for nixlbench
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get -y update && apt-get -y install autoconf libtool pkg-config \
    libgrpc-dev \
    libgrpc++-dev \
    libprotobuf-dev \
    protobuf-compiler-grpc \
    libcpprest-dev \
    libaio-dev \
    libgflags-dev \
    libcxxopts-dev

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system -U packaging 'cmake<4' ninja wheel 'setuptools<80' pybind11 meson auditwheel patchelf tomlkit

# ETCD API For RIXL benchmarks binary interacting with ETCD
RUN --mount=type=cache,target=/root/.cache/ccache \
    git clone ${ETCD_REPO} && \
    cd etcd-cpp-apiv3 && \
    git checkout ${ETCD_SHA} && \
    mkdir build && cd build && \
    cmake .. && \
    make -j$(nproc) && \
    make install

RUN --mount=type=cache,target=/root/.cache/ccache \
    cd /usr/local/src && \
    git clone ${UCX_REPO} &&  \
    cd ucx && \
    git checkout ${UCX_SHA} && \
    ./autogen.sh && \
    mkdir build && cd build && \
    ../configure \
        --prefix=${UCX_PATH} \
        --enable-shared \
        --disable-static \
        --disable-doxygen-doc \
        --enable-optimizations \
        --enable-devel-headers \
        --with-rocm=${ROCM_PATH} \
        --with-verbs \
        --with-dm \
        --enable-mt && \
    make -j && \
    make install

ENV PATH=/usr/local/ucx/bin:$PATH
ENV LD_LIBRARY_PATH=${UCX_PATH}/lib:${LD_LIBRARY_PATH}

RUN --mount=type=cache,target=/root/.cache/ccache \
    git clone ${RIXL_REPO} /opt/rixl && \
    cd /opt/rixl && \
    git checkout ${RIXL_SHA} && \
    meson setup build --prefix=${RIXL_PATH} \
                     -Ducx_path=${UCX_PATH} \
                     -Drocm_path=${ROCM_PATH} && \
    cd build && \
    ninja && \
    ninja install

# Generate RIXL wheel
RUN --mount=type=cache,target=/root/.cache/ccache \
    cd /opt/rixl && mkdir -p /app/install && \
    LD_LIBRARY_PATH=${RIXL_PATH}/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH} ./contrib/build-wheel.sh \
        --python-version ${PYTHON_VERSION} \
        --output-dir /app/install \
        --rocm-dir ${ROCM_PATH} \
        --ucx-plugins-dir ${UCX_PATH}/lib/ucx \
        --nixl-plugins-dir ${RIXL_PATH}/lib/x86_64-linux-gnu/plugins

# Nixl Bench; not strictly necessary but handy for KV-transfer performance validation
RUN --mount=type=cache,target=/root/.cache/ccache \
    cd /opt/rixl/benchmark/nixlbench &&  \
    meson setup build                    \
        -Dnixl_path=${RIXL_PATH}         \
        -Drocm_path=${ROCM_PATH}         \
        --prefix=${RIXL_BENCH_PATH} &&   \
    cd build && \
    ninja && \
    ninja install

RUN mkdir -p /export/wheels && \
    mkdir /export/packages && \
    cp -r /app/install/*.whl /export/wheels && \
    cp -r ${RIXL_BENCH_PATH} /export/packages


###
### Hipfile, LMCache
###

FROM ${BASE_IMAGE} AS build_kv

ARG PYTORCH_ROCM_ARCH
ARG HIPFILE_REPO
ARG HIPFILE_SHA
ARG LMCACHE_REPO
ARG LMCACHE_SHA

WORKDIR /usr/local/src

RUN mkdir -p /export/artifacts

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    cmake bpftrace \
          libboost-all-dev \
          libmount-dev \
          ninja-build \
          vim && \
    rm -rf /var/lib/apt/lists/*

# Install build tool
RUN uv pip install --system build

# Clone and checkout LMCache
# NOTE: Remove NIXL wheels pulled by upstream LMCache unconditionally. If they remain, VLLM
# tries to import non-existent CUDA shared object at runtime.
COPY patches /app/patches
RUN git clone ${LMCACHE_REPO} && \
    git config --global user.email "foo@bar.com" && \
    git config --global user.name "Docker Build" && \
    cd LMCache && \
    git checkout ${LMCACHE_SHA} && \
    git am /app/patches/lmcache/*.patch && \
    sed -i'' s/torch==2.11.0/torch==2.10.0/g pyproject.toml && \
    uv pip install --system -r requirements/build.txt && \
    PYTORCH_ROCM_ARCH="${PYTORCH_ROCM_ARCH}" \
    TORCH_DONT_CHECK_COMPILER_ABI=1 \
    CXX=hipcc \
    BUILD_WITH_HIP=1 \
    python3 -m build --wheel --no-isolation && \
    cp /usr/local/src/LMCache/dist/*.whl /export/artifacts

# Build & install hipFile libs, headers, and python bindings
# invalid sha here,

RUN git clone --no-checkout --filter=blob:none ${HIPFILE_REPO} && \
    cd rocm-systems && \
    git sparse-checkout set --cone projects/hipfile && \
    git checkout "${HIPFILE_SHA}" && \
    mkdir build && cd build && \
    cmake -DGPU_TARGETS=${PYTORCH_ROCM_ARCH} -DCMAKE_BUILD_TYPE=Release -DCMAKE_HIP_PLATFORM=amd ../projects/hipfile && cmake --build . -j && cpack -G DEB && \
    dpkg -i hipfile*deb && \
    cp hipfile*deb /export/artifacts && \
    cd ../projects/hipfile/python && \
    python -m build --wheel -Ccmake.define.HIPFILE_INCLUDE_DIR=../include -Ccmake.define.HIP_INCLUDE_DIR=/opt/rocm/include && \
    cp dist/hipfile-*.whl /export/artifacts


###
### Runtime Stage
###

FROM base AS runtime

ARG PYTORCH_ROCM_ARCH

WORKDIR /app

# Install runtime dependencies for hipfile (boost libraries needed at runtime)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        libmount-dev \
    && rm -rf /var/lib/apt/lists/*

RUN --mount=type=bind,from=build_rixl,src=/export/wheels,target=/export/wheels \
    --mount=type=bind,from=build_rixl,src=/export/packages,target=/export/packages \
    --mount=type=bind,from=build_kv,src=/export/artifacts,target=/export/artifacts \
    --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system /export/wheels/*.whl && \
    cp -r /export/packages/* /opt && \
    dpkg -i /export/artifacts/hipfile*deb && \
    uv pip install --system /export/artifacts/*.whl && \
    uv pip uninstall --system nixl nixl-cu12 cupy-cuda12x cufile-python cuda-pathfinder

# Update library cache after installing all packages
RUN ldconfig

# longdocqa:
# - matplotlib
# multiturn:
# - xlsxwriter
RUN uv pip install --system pandas matplotlib xlsxwriter

# Update LD_LIBRARY_PATH to include all necessary library paths
ENV LD_LIBRARY_PATH=/usr/lib:/usr/local/lib:${ROCM_PATH}/lib:${UCX_PATH}/lib:${RIXL_PATH}/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH}

# Verify installations with detailed diagnostics
RUN echo "=== Verifying LMCache installation ===" && \
    python3 -c "import lmcache; print('LMCache installed successfully')" && \
    echo "=== Verifying hipfile installation ===" && \
    python3 -c "import hipfile; print('hipfile installed successfully at:', hipfile.__file__)" && \
    echo "=== Checking hipfile library files ===" && \
    find /usr -name "*hipfile*" -type f 2>/dev/null | head -20 || true

# Set environment for ROCm
ENV PYTORCH_ROCM_ARCH=${PYTORCH_ROCM_ARCH}

# Default command
CMD ["vllm", "serve"]
