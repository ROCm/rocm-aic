# Benchmark CSVs, plots, container logs and the Prometheus TSDB all land under
# logs/<job-id>/ (or logs/manual/ for non-Slurm runs) -- one ignored tree.
logs/

# stray Slurm job logs written to the tree root (e.g. a manual `sbatch` run, or
# jobs from before per-job logs/<job-id>/ logging); the cliff job now writes to
# logs/<job-id>/cliff.out.
aai-day-cliff-*.out
__pycache__/
*.pyc

# `make export` artifacts (aai-day-release-<date>-<rev>.tar.gz by default).
/*.tar.gz
