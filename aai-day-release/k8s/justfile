set shell := ["bash", "-o", "pipefail", "-c"]

# Default namespace and image settings.
# Override with `just NAMESPACE=my-ns deploy-tp2` or set env vars.
NAMESPACE      := env_var_or_default("AAI_DAY_NAMESPACE", "aai-day")
IMAGE_REGISTRY := env_var_or_default("AAI_DAY_IMAGE_REGISTRY", "ghcr.io/rocm")
IMAGE_NAME     := env_var_or_default("AAI_DAY_IMAGE_NAME", "rocm-aic-aai-day")
IMAGE_TAG      := env_var_or_default("AAI_DAY_IMAGE_TAG", "latest")
MANIFESTS_DIR  := justfile_directory() + "/manifests"

# --------------------------------------------------------------------------
# Setup
# --------------------------------------------------------------------------

# Create the aai-day namespace.
create-namespace:
    kubectl create namespace {{NAMESPACE}} --dry-run=client -o yaml | kubectl apply -f -

# Register HuggingFace token as a Kubernetes secret.
# Reads HF_TOKEN from the environment.
register-hf-token: create-namespace
    @[ -n "${HF_TOKEN:-}" ] || { echo "ERROR: HF_TOKEN env var is not set"; exit 1; }
    kubectl create secret generic aai-day-hf-token \
        --namespace {{NAMESPACE}} \
        --from-literal=HF_TOKEN="${HF_TOKEN}" \
        --dry-run=client -o yaml | kubectl apply -f -
    @echo "HuggingFace token secret registered in namespace '{{NAMESPACE}}'."

# --------------------------------------------------------------------------
# Deploy flavors
# --------------------------------------------------------------------------

# Deploy TP=2, DRAM L1 only (quickstart — no persistent storage required).
deploy-tp2: create-namespace
    kustomize build {{MANIFESTS_DIR}}/flavors/tp2-dram-l1 \
        | IMAGE_REGISTRY={{IMAGE_REGISTRY}} IMAGE_NAME={{IMAGE_NAME}} IMAGE_TAG={{IMAGE_TAG}} \
          envsubst \
        | kubectl apply --namespace {{NAMESPACE}} -f -
    @echo "Deployed tp2-dram-l1. Check status with: just status"

# Deploy TP=2 with NFS L2 KV cache tier (requires ReadWriteMany PVC).
deploy-tp2-nfs: create-namespace
    kustomize build {{MANIFESTS_DIR}}/flavors/tp2-nfs-l2 \
        | IMAGE_REGISTRY={{IMAGE_REGISTRY}} IMAGE_NAME={{IMAGE_NAME}} IMAGE_TAG={{IMAGE_TAG}} \
          envsubst \
        | kubectl apply --namespace {{NAMESPACE}} -f -
    @echo "Deployed tp2-nfs-l2."

# Deploy TP=4 with local NVMe L2 KV cache tier.
deploy-tp4: create-namespace
    kustomize build {{MANIFESTS_DIR}}/flavors/tp4-nvme-l2 \
        | IMAGE_REGISTRY={{IMAGE_REGISTRY}} IMAGE_NAME={{IMAGE_NAME}} IMAGE_TAG={{IMAGE_TAG}} \
          envsubst \
        | kubectl apply --namespace {{NAMESPACE}} -f -
    @echo "Deployed tp4-nvme-l2."

# Deploy TP=8 with GDS NVMe slab L1 (hipFile mode — requires 8 GPUs per node).
deploy-tp8: create-namespace
    kustomize build {{MANIFESTS_DIR}}/flavors/tp8-gds-l1 \
        | IMAGE_REGISTRY={{IMAGE_REGISTRY}} IMAGE_NAME={{IMAGE_NAME}} IMAGE_TAG={{IMAGE_TAG}} \
          envsubst \
        | kubectl apply --namespace {{NAMESPACE}} -f -
    @echo "Deployed tp8-gds-l1."

# --------------------------------------------------------------------------
# Teardown
# --------------------------------------------------------------------------

# Remove all aai-day resources from the cluster.
teardown:
    kubectl delete namespace {{NAMESPACE}} --ignore-not-found

# --------------------------------------------------------------------------
# Operations
# --------------------------------------------------------------------------

# Show pod and deployment status.
status:
    kubectl get pods,deployments,services --namespace {{NAMESPACE}} -o wide

# Tail logs from the vllm container (most recent pod).
logs:
    kubectl logs --namespace {{NAMESPACE}} \
        -l app=aai-day-vllm \
        -c vllm \
        --tail=100 \
        --follow=false

# Tail logs from the lmcache-server sidecar (most recent pod).
logs-lmcache:
    kubectl logs --namespace {{NAMESPACE}} \
        -l app=aai-day-vllm \
        -c lmcache-server \
        --tail=100 \
        --follow=false

# Follow logs from both containers on the most recent pod.
logs-follow:
    @POD=$(kubectl get pods --namespace {{NAMESPACE}} -l app=aai-day-vllm \
        --sort-by=.metadata.creationTimestamp -o jsonpath='{.items[-1].metadata.name}'); \
    echo "Following logs on pod: $POD"; \
    kubectl logs --namespace {{NAMESPACE}} "$POD" --all-containers --follow

# Forward vLLM API port to localhost:8000.
port-forward:
    kubectl port-forward --namespace {{NAMESPACE}} \
        svc/aai-day-vllm 8000:8000

# Run a quick health check against the forwarded API.
health-check:
    curl -sf http://localhost:8000/v1/models | python3 -m json.tool

# Build and dry-run the base manifests (no cluster required).
lint:
    kustomize build {{MANIFESTS_DIR}}/base
    kustomize build {{MANIFESTS_DIR}}/flavors/tp2-dram-l1
    kustomize build {{MANIFESTS_DIR}}/flavors/tp2-nfs-l2
    kustomize build {{MANIFESTS_DIR}}/flavors/tp4-nvme-l2
    kustomize build {{MANIFESTS_DIR}}/flavors/tp8-gds-l1
    @echo "All kustomize builds succeeded."
